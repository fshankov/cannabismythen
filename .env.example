# Keystatic GitHub Mode — Required for deployed CMS
# See docs/editor-guide.md for full setup instructions.

# GitHub OAuth App credentials (created at https://github.com/settings/apps)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# A random secret string for signing tokens (generate with: openssl rand -hex 32)
KEYSTATIC_SECRET=

# Site password — protects the entire public site
SITE_PASSWORD=

# BugHerd feedback widget — staging-only.
# Set this in Netlify scoped to "Deploy previews" so the widget loads on
# preview builds for reviewers but stays absent locally and in production.
# Get the key from BugHerd → project Settings → Installation → `apikey=…`.
# Leave unset for local dev unless you're testing the widget itself.
# See _local/bugherd-setup.md for the full reviewer-onboarding workflow.
PUBLIC_BUGHERD_KEY=
