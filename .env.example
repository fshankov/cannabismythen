# Keystatic GitHub Mode — Required for deployed CMS
# See docs/editor-guide.md for full setup instructions.

# GitHub OAuth App credentials (created at https://github.com/settings/apps)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# A random secret string for signing tokens (generate with: openssl rand -hex 32)
KEYSTATIC_SECRET=
