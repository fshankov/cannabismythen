# Dependencies
node_modules/

# Build output
dist/
.netlify/

# Astro
.astro/

# Environment variables
.env
.env.local
.env.production

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp
*.swo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local reference materials (source docs, design specs, AI workflow guides)
# Not part of the website — safe to exclude from version control
_local/

# Claude Code local tooling — per-machine settings and worktree scratch space
.claude/settings.local.json
.claude/worktrees/

# Vite/esbuild orphan temp files. @astrojs/markdoc reloads markdoc.config.mjs
# by writing a sibling esbuild-compiled file and immediately re-importing it.
# If the dev server is killed mid-import (Ctrl-C during reload, crash), the
# temp file is left behind. They have no functional purpose — Vite writes
# fresh ones on every dev start. Archived copies at
# _local/archive/markdoc-timestamps-2026-05-11/ for reference.
markdoc.config.timestamp-*.mjs

# Session artifacts — local-only tooling traces. Kept on disk for reference
# (CLAUDE.md says "don't refactor them") but excluded from the public repo.
# .playwright-mcp holds Playwright MCP run dumps + screenshots.
# .superpowers holds brainstorm session state (server pids/logs/html).
.playwright-mcp/
.superpowers/

# Playwright visual-regression scratch output (reports + actual/diff images on
# failure). The committed baselines live in tests/visual/**/*-snapshots/ and are
# NOT ignored.
test-results/
playwright-report/

# ────────────────────────────────────────────────────────────────────
# Internal team tracker — NOT for the public GitHub repo. Contains
# BugHerd review data, internal session reports, team-only decisions.
# Lives at public/tracker/ locally so dev preview works, but is
# excluded from git so it never reaches the open repo. To deploy the
# tracker for the team, see _local/team-only/tracker-hosting.md
# (separate private Netlify project). Run ./scripts/sync-tracker.sh
# to refresh public/tracker/ from the Cowork artifact for local dev.
# ────────────────────────────────────────────────────────────────────
public/tracker/
docs/tracker/
