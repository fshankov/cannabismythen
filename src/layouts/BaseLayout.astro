---
import "../styles/global.css";
import "@fontsource-variable/inter";
import "@fontsource/dm-serif-display";
import "@fontsource/source-serif-4/700.css";
import "@fontsource/source-serif-4/700-italic.css";

interface Props {
  title: string;
  description?: string;
  heroMode?: boolean;
  /** When true, paints the subtle dotted page texture (the
   *  Fakten-Karten look) on <body> via the `.dot-texture` class.
   *  Used on Fakten-Karten, Quiz, Daten-Explorer and Meine Interessen. */
  bgTexture?: boolean;
  /** Extra class(es) added verbatim to <body>. Use for page-specific
   *  CSS hooks (e.g. "fakten-karten-page" for the SVG tile texture). */
  extraBodyClass?: string;
  /** Stage 8: per-page OG image URL (absolute or root-relative). When
   *  set, emits og:image + twitter:card meta. og:title/description
   *  derive from `title`/`description`; og:url from the current request. */
  ogImage?: string;
  /** When true, suppress the default minimal copyright footer — the page
   *  provides its own footer (e.g. the homepage's rich SiteFooter). */
  hideFooter?: boolean;
}

const {
  title,
  description = "Wissenschaftliche Informationen zu Cannabis-Mythen",
  heroMode = false,
  bgTexture = false,
  extraBodyClass,
  ogImage,
  hideFooter = false,
} = Astro.props;

// PREVIEW BANNER — flip to false before public launch
const SHOW_PREVIEW_BANNER = true;

const bodyClass = [
  heroMode ? "has-hero" : "",
  bgTexture ? "dot-texture" : "",
  extraBodyClass ?? "",
]
  .filter(Boolean)
  .join(" ");

// Stage 8 — resolve absolute OG URL once for og:image + og:url. `Astro.site`
// is set in astro.config when the production origin is known. Falls back to
// the current request origin so dev + preview builds emit usable absolute
// URLs anyway.
const siteUrl =
  Astro.site?.toString().replace(/\/$/, "") ??
  `${Astro.url.protocol}//${Astro.url.host}`;
const ogImageAbs = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : `${siteUrl}${ogImage}`
  : null;
const ogUrl = `${siteUrl}${Astro.url.pathname}`;
const fullTitle = `${title} | Cannabis: Mythen & Evidenz`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    {/* Stage 8 — OG / Twitter card meta */}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    {ogImageAbs && (
      <Fragment>
        <meta property="og:image" content={ogImageAbs} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={ogImageAbs} />
      </Fragment>
    )}

    {/* Matomo Analytics — cookieless mode (no GDPR banner needed) */}
    {/* TODO: Replace MATOMO_URL and SITE_ID with real values before production */}
    <script is:inline>
      var _paq = window._paq = window._paq || [];
      _paq.push(['disableCookies']);
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        var u="https://MATOMO_URL/";
        _paq.push(['setTrackerUrl', u+'matomo.php']);
        _paq.push(['setSiteId', 'SITE_ID']);
        var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
        g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
      })();
    </script>

    {/* Feedbucket feedback widget — vendor snippet from cdn.feedbucket.app.
        Two-way Asana sync per CLAUDE.md "Tracker workflow": pins on the live
        site create Asana tasks (project CannabisMythen, gid 1214704634010891);
        replies in Asana prefixed with @feedbucket post back to the widget.
        Replaces the previous BugHerd Phase 1 install (Studierendentest, Mai
        2026) — historical pins are triaged in _local/archive/bugherd/triage.md.

        The install IIFE is wrapped in a path check so reviewers can't pin on
        the login gate, API routes, or the Keystatic CMS. Feedbucket's
        documented init doesn't expose a runtime hide/show hook, so
        conditional injection is the equivalent of the previous BugHerd
        post-load hide pattern.

        Re-enabled 2026-06-01 (trial active again). Three pieces flip
        together: this head install script, the footer "Feedback geben"
        pill, and the trigger script (search for "feedbucketKey" in this
        file). The vendor key (lpuJyzKJ9oT0o2uKlRSk) and Query Trigger
        secret (cm-feedback-2026) stay valid as long as the Feedbucket
        project isn't deleted. To disable again, wrap each of the three
        blocks back in FEEDBUCKET-DISABLED-START / FEEDBUCKET-DISABLED-END
        comment markers and restore the plain copyright line in the
        footer. */}
    <script is:inline>
      (function (k) {
        var path = window.location.pathname;
        if (
          path === "/login" ||
          path.startsWith("/api/") ||
          path.startsWith("/keystatic/")
        ) {
          return;
        }
        var s = document.createElement("script");
        s.defer = true;
        s.src = "https://cdn.feedbucket.app/assets/feedbucket.js";
        s.dataset.feedbucket = k;
        document.head.appendChild(s);
      })("lpuJyzKJ9oT0o2uKlRSk");
    </script>

    {/* Mark <html> as preview-open before body renders so the nav pill stays
        hidden under the overlay banner from first paint (no flash).
        Behaviour: once dismissed, the banner stays closed across in-session
        navigation. A full page reload (Cmd-R / F5 / browser reload button)
        clears the dismissed flag so the banner reappears. */}
    {SHOW_PREVIEW_BANNER && (
      <script is:inline>
        (function() {
          try {
            var entries = performance.getEntriesByType && performance.getEntriesByType('navigation');
            var navType = entries && entries[0] && entries[0].type;
            if (navType === 'reload') {
              sessionStorage.removeItem('cm-preview-state');
            }
          } catch (e) { /* sessionStorage / performance API unavailable */ }
          if (sessionStorage.getItem('cm-preview-state') !== 'collapsed') {
            document.documentElement.classList.add('cm-preview-open');
          }
        })();
      </script>
    )}
  </head>
  <body class={bodyClass}>

    {/* PREVIEW BANNER — remove Fragment before public launch */}
    {SHOW_PREVIEW_BANNER && (
      <Fragment>
        <div id="preview-banner" class="preview-banner" role="note" aria-label="Vorabversion-Hinweis">
          <div class="preview-banner__inner">
            <svg class="preview-banner__icon" aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
              <line x1="12" y1="9" x2="12" y2="13"/>
              <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            <div class="preview-banner__text">
              <p>
                <strong>Vorschauversion:</strong> Diese Website befindet sich noch in der Entwicklung und wurde noch nicht offiziell durch das ISD&nbsp;Hamburg abschließend freigegeben. Inhalte können sich bis zum offiziellen Start noch ändern.
              </p>
              <p>
                Für die Vollständigkeit und Richtigkeit der bereitgestellten Informationen wird keine Gewähr übernommen.
              </p>
              <p>
                Alle Inhalte dienen ausschließlich Informations- und Forschungszwecken und ersetzen keine persönliche ärztliche Beratung. Bei gesundheitlichen Fragen wenden Sie sich bitte an eine qualifizierte Fachkraft.
              </p>
            </div>
            <button class="preview-banner__close-btn" type="button" id="previewBannerClose" aria-label="Hinweis schließen">
              <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
              Schließen
            </button>
          </div>
        </div>

        <button id="preview-fab" class="preview-fab" type="button" aria-label="Vorabversion-Hinweis anzeigen">
          <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </button>
      </Fragment>
    )}

    <!-- Feathered blur strip behind the floating pill -->
    <div class="nav-blur-shield" aria-hidden="true"></div>

    <!-- Floating pill nav -->
    <div class="nav-wrapper">
      <nav class="nav" id="mainNav" aria-label="Hauptnavigation">

        <a href="/" class="nav__brand" aria-label="Cannabis Mythen – Startseite">
          <span class="cm-logo" aria-hidden="true">
            <span class="cm-lens" aria-hidden="true"></span>
            <svg class="cm-art" viewBox="0 0 64 64" aria-hidden="true">
              <defs>
                <clipPath id="cmLens"><circle cx="30" cy="30" r="14.6"/></clipPath>
                <radialGradient id="cmSpec" cx="0.5" cy="0.5" r="0.5">
                  <stop offset="0" stop-color="#fff" stop-opacity=".55"/><stop offset="1" stop-color="#fff" stop-opacity="0"/>
                </radialGradient>
                <radialGradient id="cmDepth" cx="0.5" cy="0.62" r="0.62">
                  <stop offset=".55" stop-color="#000" stop-opacity="0"/><stop offset="1" stop-color="#0a140f" stop-opacity=".2"/>
                </radialGradient>
                <linearGradient id="cmRim" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0" stop-color="#fff" stop-opacity=".5"/><stop offset=".5" stop-color="#fff" stop-opacity="0"/>
                </linearGradient>
                <filter id="cmBB" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="1.15"/></filter>
                <filter id="cmSB" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="1.5"/></filter>
                <filter id="cmHZ" x="-30%" y="-30%" width="160%" height="160%"><feGaussianBlur stdDeviation=".26"/></filter>
              </defs>
              <g clip-path="url(#cmLens)">
                <g filter="url(#cmBB)" opacity=".42" transform="translate(30 26.5) scale(1.18) translate(-12 -9)" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 16h20" stroke="var(--cm-mark-soft)"/><path d="M12 2v14" stroke="var(--cm-mark)"/><path d="m5 9 7 7 7-7" stroke="var(--cm-mark)"/>
                </g>
                <g filter="url(#cmHZ)" transform="translate(30 26.5) scale(.86) translate(-12 -9)" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 16h20" stroke="var(--cm-mark-soft)"/><path d="M12 2v14" stroke="var(--cm-mark)"/><path d="m5 9 7 7 7-7" stroke="var(--cm-mark)"/>
                </g>
                <circle cx="30" cy="30" r="14.6" fill="#fff" fill-opacity=".08"/>
                <circle cx="30" cy="30" r="14.6" fill="url(#cmDepth)"/>
                <g filter="url(#cmSB)"><ellipse cx="24.5" cy="23" rx="9.5" ry="6" transform="rotate(-32 24.5 23)" fill="url(#cmSpec)"/></g>
                <path d="M19.5 24 A14.6 14.6 0 0 1 40 19" fill="none" stroke="url(#cmRim)" stroke-width="1.4" stroke-linecap="round"/>
              </g>
              <g fill="none" stroke="var(--cm-ring)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="30" cy="30" r="16"/><path d="M50 50 41.3 41.3"/>
              </g>
            </svg>
          </span>
          <span class="nav__brand-text">Cannabis<span class="nav__brand-myth">Mythen</span></span>
        </a>

        <ul class="nav__links" role="list">
          <li><a href="/fakten-karten/"    class="nav__link">Fakten-Karten</a></li>
          <li><a href="/daten-explorer/"   class="nav__link">Daten-Explorer</a></li>
          <li><a href="/meine-interessen/" class="nav__link">Meine Interessen</a></li>
          <li><a href="/quiz/"             class="nav__link">Quiz</a></li>
          <li><a href="/projekt/"          class="nav__link">Über das Projekt</a></li>
        </ul>

        <button class="nav__hamburger" id="hamburgerBtn"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="navDrawer">
          <span class="nav__hamburger-line"></span>
          <span class="nav__hamburger-line"></span>
          <span class="nav__hamburger-line"></span>
        </button>

      </nav>
      <!-- Quiz progress portal — QuizPlayer portals its strip here -->
      <div id="quiz-progress-slot"></div>
    </div>

    <!-- Mobile/tablet drawer (full-viewport, outside the pill wrapper) -->
    <div class="nav__drawer-overlay" id="navDrawer"
         role="dialog" aria-modal="true" aria-label="Navigationsmenü">
      <div class="nav__drawer">
        <ul class="nav__drawer-list" role="list">
          <li class="nav__drawer-item"><a href="/fakten-karten/"    class="nav__drawer-link">Fakten-Karten</a></li>
          <li class="nav__drawer-item"><a href="/daten-explorer/"   class="nav__drawer-link">Daten-Explorer</a></li>
          <li class="nav__drawer-item"><a href="/meine-interessen/" class="nav__drawer-link">Meine Interessen</a></li>
          <li class="nav__drawer-item"><a href="/quiz/"             class="nav__drawer-link">Quiz</a></li>
          <li class="nav__drawer-item"><a href="/projekt/"          class="nav__drawer-link">Über das Projekt</a></li>
        </ul>
      </div>
    </div>
    <main>
      <slot />
    </main>
    <footer id="main-content" style={hideFooter ? "display:none" : undefined}>
      {/* Feedbucket re-enabled 2026-06-01. To disable: replace this <p>
          with the plain `<p>&copy; … CaRM-Projekt</p>` line and wrap this
          block back in FEEDBUCKET-DISABLED-START / FEEDBUCKET-DISABLED-END
          markers (along with the head script and trigger script). */}
      <p>
        &copy; {new Date().getFullYear()} CaRM-Projekt
        <span class="footer-sep" aria-hidden="true">·</span>
        <a
          id="footer-feedback-trigger"
          class="footer-feedback-link"
          href="?feedbucketKey=cm-feedback-2026"
          rel="nofollow"
        >Feedback geben</a>
      </p>
    </footer>

    {/* Reviewer-only feedback trigger (re-enabled 2026-06-01).
        Clicking the footer link reloads the current page with
        ?feedbucketKey=<secret> appended; Feedbucket's Query Trigger
        (configured in the project's Widget settings) then activates the
        widget for this visitor and sets a persistence cookie for 1 hour, so
        the widget stays available on subsequent pages without the key.

        The href is rewritten on load so existing query params are preserved
        (e.g. /quiz/?theme=… stays intact, just gains feedbucketKey). The
        secret value here MUST match what's configured in the Feedbucket
        project dashboard. If you rotate the secret, update both places. */}
    <script is:inline>
      (function () {
        var a = document.getElementById('footer-feedback-trigger');
        if (!a) return;
        try {
          var u = new URL(window.location.href);
          u.searchParams.set('feedbucketKey', 'cm-feedback-2026');
          a.href = u.toString();
        } catch (e) {
          // URL ctor failed (very old browser) — leave the static href; the
          // default href is still valid, it just discards prior query params.
        }
      })();
    </script>

    {/* Active nav link: sets aria-current + active class from URL */}
    <script is:inline>
      (function () {
        var path = window.location.pathname;
        document.querySelectorAll('.nav__link, .nav__drawer-link').forEach(function (a) {
          var href = a.getAttribute('href');
          var active = href === path || (href !== '/' && path.startsWith(href));
          if (active) {
            a.classList.add(
              a.classList.contains('nav__link') ? 'nav__link--active' : 'nav__drawer-link--active'
            );
            a.setAttribute('aria-current', 'page');
          }
        });
      })();
    </script>

    {/* Scroll elevation: adds .nav--scrolled once user scrolls past threshold */}
    <script is:inline>
      (function () {
        var nav = document.getElementById('mainNav');
        if (!nav) return;
        var isHero = document.body.classList.contains('has-hero');
        var threshold = isHero ? window.innerHeight * 0.85 : 8;
        if (!isHero) nav.classList.add('nav--scrolled');
        function onScroll() {
          nav.classList.toggle('nav--scrolled', window.scrollY > threshold);
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        if (isHero) onScroll();
      })();
    </script>

    {/* Drawer: hamburger open/close, overlay click, Escape key */}
    <script is:inline>
      (function () {
        var btn     = document.getElementById('hamburgerBtn');
        var overlay = document.getElementById('navDrawer');
        if (!btn || !overlay) return;
        function open() {
          overlay.classList.add('nav__drawer-overlay--open');
          btn.setAttribute('aria-expanded', 'true');
          btn.setAttribute('aria-label', 'Menü schließen');
          document.body.style.overflow = 'hidden';
        }
        function close() {
          overlay.classList.remove('nav__drawer-overlay--open');
          btn.setAttribute('aria-expanded', 'false');
          btn.setAttribute('aria-label', 'Menü öffnen');
          document.body.style.overflow = '';
        }
        btn.addEventListener('click', function () {
          overlay.classList.contains('nav__drawer-overlay--open') ? close() : open();
        });
        overlay.addEventListener('click', function (e) {
          if (e.target === overlay) close();
        });
        document.querySelectorAll('.nav__drawer-link').forEach(function (l) {
          l.addEventListener('click', close);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && overlay.classList.contains('nav__drawer-overlay--open')) {
            close();
            btn.focus();
          }
        });
      })();
    </script>

    {/* Preview banner: overlays the nav pill; × collapses to a FAB, FAB re-opens */}
    {SHOW_PREVIEW_BANNER && (
      <script is:inline>
        (function () {
          var root   = document.documentElement;
          var banner = document.getElementById('preview-banner');
          var fab    = document.getElementById('preview-fab');
          if (!banner) return;

          function collapse() {
            banner.style.display = 'none';
            root.classList.remove('cm-preview-open');
            if (fab) fab.classList.add('preview-fab--visible');
            try { sessionStorage.setItem('cm-preview-state', 'collapsed'); } catch (e) {}
          }

          function expand() {
            banner.style.display = '';
            root.classList.add('cm-preview-open');
            if (fab) fab.classList.remove('preview-fab--visible');
            try { sessionStorage.removeItem('cm-preview-state'); } catch (e) {}
          }

          /* Restore collapsed state from earlier this session. The head
             script already added cm-preview-open when not collapsed, and
             clears the flag entirely on a hard reload. */
          if (sessionStorage.getItem('cm-preview-state') === 'collapsed') {
            banner.style.display = 'none';
            if (fab) fab.classList.add('preview-fab--visible');
          }

          var closeBtn = document.getElementById('previewBannerClose');
          if (closeBtn) closeBtn.addEventListener('click', collapse);

          if (fab) fab.addEventListener('click', expand);
        })();
      </script>
    )}

    {/* Stage F commit 1 (2026-05-23) — publish the live header height as a
        CSS variable so `main { padding-top }` can compensate for the
        feedback strip the quiz portals into the fixed `body > header`.
        Without this, the strip overflows into the page content area
        (the QuizCard statement ends up hidden behind the strip on first
        paint). The ResizeObserver catches the height change every time
        the strip mounts / changes size; the fallback `--nav-height`
        keeps non-quiz pages unaffected. */}
    <script is:inline>
      (function () {
        var header = document.querySelector('.nav-wrapper');
        if (!header) return;
        function publishHeight() {
          var rect = header.getBoundingClientRect();
          var h = Math.max(140, rect.bottom + 16);
          document.documentElement.style.setProperty('--header-height', h + 'px');
        }
        publishHeight();
        window.addEventListener('resize', publishHeight, { passive: true });
        if (typeof ResizeObserver === 'function') {
          new ResizeObserver(publishHeight).observe(header);
        }
      })();
    </script>

    {/* Decision D: Mobile bottom tab bar — visible < 1024px, hidden on desktop */}
    <nav class="mobile-tab-bar" aria-label="Mobile-Navigation">
      <a href="/fakten-karten/" class="mobile-tab-bar__item">
        <svg class="mobile-tab-bar__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        <span>Karten</span>
      </a>
      <a href="/daten-explorer/" class="mobile-tab-bar__item">
        <svg class="mobile-tab-bar__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/></svg>
        <span>Daten</span>
      </a>
      <a href="/quiz/" class="mobile-tab-bar__item">
        <svg class="mobile-tab-bar__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>
        <span>Quiz</span>
      </a>
      <a href="/meine-interessen/" class="mobile-tab-bar__item">
        <svg class="mobile-tab-bar__icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
        <span>Interessen</span>
