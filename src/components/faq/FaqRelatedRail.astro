---
import {
  dashboardLinkLabel,
  loadMythPopupData,
  normalizeMythId,
  type FaqQuestion,
} from "@lib/faq";

interface Props {
  question: FaqQuestion;
  /** Optional override of quiz titles by slug, looked up at the page level. */
  quizTitles?: Record<string, string>;
}

const { question, quizTitles = {} } = Astro.props;

// Resolve myth IDs to popup-ready entries (id + full statement). The myth
// IS the popup — the related rail no longer links to standalone factsheet
// pages, it triggers the same slide-in panel MythPopupHost manages.
const { mythIndex } = await loadMythPopupData();

type RailMyth = { id: string; title: string };
function lookupMyth(rawId: string): RailMyth | null {
  const norm = normalizeMythId(rawId);
  if (!norm) return null;
  const meta = mythIndex[norm] ?? mythIndex[rawId];
  if (!meta) return null;
  return { id: norm, title: meta.title };
}

const primary: RailMyth | null = question.primaryMyth
  ? lookupMyth(question.primaryMyth)
  : null;
const related: RailMyth[] = question.relatedMyths
  .map((m) => lookupMyth(m))
  .filter((m): m is RailMyth => m !== null);

const quiz = question.relatedQuiz
  .filter((slug) => Boolean(slug))
  .map((slug) => ({
    slug,
    title: quizTitles[slug] ?? slug.replace(/^quiz-/, "").replace(/-/g, " "),
    url: `/quiz/${slug}/`,
  }));

const dashboard = question.relatedDashboard.map((url) => ({
  url,
  label: dashboardLinkLabel(url),
}));

const hasRail = primary || related.length > 0 || quiz.length > 0 || dashboard.length > 0;
---

{hasRail && (
  <div class="faq-related-rail">
    {primary && (
      <div class="faq-related-rail__group faq-related-rail__group--primary">
        <span class="faq-related-rail__heading">Mythos</span>
        <button
          type="button"
          class="faq-related-rail__link faq-related-rail__link--primary faq-myth-link"
          data-faq-myth-id={primary.id}
          aria-haspopup="dialog"
        >
          <span class="faq-related-rail__icon" aria-hidden="true">▸</span>
          {primary.title}
        </button>
      </div>
    )}

    {related.length > 0 && (
      <div class="faq-related-rail__group">
        <span class="faq-related-rail__heading">Verwandte Mythen</span>
        <ul class="faq-related-rail__list">
          {related.map((m) => (
            <li>
              <button
                type="button"
                class="faq-related-rail__link faq-myth-link"
                data-faq-myth-id={m.id}
                aria-haspopup="dialog"
              >
                {m.title}
              </button>
            </li>
          ))}
        </ul>
      </div>
    )}

    {quiz.length > 0 && (
      <div class="faq-related-rail__group">
        <span class="faq-related-rail__heading">Quiz</span>
        <ul class="faq-related-rail__list">
          {quiz.map((q) => (
            <li>
              <a href={q.url} class="faq-related-rail__link">
                {q.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {dashboard.length > 0 && (
      <div class="faq-related-rail__group">
        <span class="faq-related-rail__heading">Daten</span>
        <ul class="faq-related-rail__list">
          {dashboard.map((d) => (
            <li>
              <a href={d.url} class="faq-related-rail__link">
                {d.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
)}
