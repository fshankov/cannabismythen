---
import {
  dashboardLinkLabel,
  dashboardLinkUrl,
  loadMythPopupData,
  normalizeMythId,
  type FaqMythPopupIndexEntry,
  type FaqQuestion,
} from "@lib/faq";

interface Props {
  question: FaqQuestion;
  /** Popup myth index — pass down from the page to skip the per-component
   *  `loadMythPopupData()` call. When omitted the helper is loaded here,
   *  which is cached so the cost is one-time per dev-server process. */
  mythIndex?: Record<string, FaqMythPopupIndexEntry>;
}

const { question, mythIndex: mythIndexProp } = Astro.props;

// Resolve myth IDs to popup-ready entries (id + full statement). The myth
// IS the popup — the related rail no longer links to standalone factsheet
// pages, it triggers the same slide-in panel MythPopupHost manages. The
// data is normally hoisted to the page level and passed in via the
// `mythIndex` prop; we fall back to the (now-cached) helper for any
// callsite that doesn't yet pass it.
const mythIndex = mythIndexProp ?? (await loadMythPopupData()).mythIndex;

type RailMyth = { id: string; title: string };
function lookupMyth(rawId: string): RailMyth | null {
  const norm = normalizeMythId(rawId);
  if (!norm) return null;
  const meta = mythIndex[norm] ?? mythIndex[rawId];
  if (!meta) return null;
  return { id: norm, title: meta.title };
}

const primary: RailMyth | null = question.primaryMyth
  ? lookupMyth(question.primaryMyth)
  : null;
const related: RailMyth[] = question.relatedMyths
  .map((m) => lookupMyth(m))
  .filter((m): m is RailMyth => m !== null);

// BugHerd 4.7 (2026-06-03, ISD): the generic Daten-Explorer start-page link
// is redundant when a specific dashboard view is already linked. Drop the bare
// "/daten-explorer/" (and its legacy "/zahlen-und-fakten/" form) in that case;
// questions that ONLY link the generic root keep it.
const GENERIC_DASHBOARD_URLS = new Set(["/daten-explorer/", "/zahlen-und-fakten/"]);
const hasSpecificDashboard = question.relatedDashboard.some(
  (url) => !GENERIC_DASHBOARD_URLS.has(url),
);
const dashboard = question.relatedDashboard
  .filter((url) => !(hasSpecificDashboard && GENERIC_DASHBOARD_URLS.has(url)))
  .map((url) => ({
    // BugHerd 4.8 (2026-06-03): resolve named-view links (informationswege,
    // minderjaehrige, …) to working ?view/?indicator/?group deep-links. The
    // label is still derived from the ORIGINAL url so the caption is unchanged.
    url: dashboardLinkUrl(url),
    label: dashboardLinkLabel(url),
  }));

const hasRail = primary || related.length > 0 || dashboard.length > 0;
---

{hasRail && (
  <div class="faq-related-rail">
    {primary && (
      <div class="faq-related-rail__group faq-related-rail__group--primary">
        <span class="faq-related-rail__heading">Mythos</span>
        <button
          type="button"
          class="faq-related-rail__link faq-related-rail__link--primary faq-myth-link"
          data-faq-myth-id={primary.id}
          aria-haspopup="dialog"
        >
          <span class="faq-related-rail__icon" aria-hidden="true">▸</span>
          {primary.title}
        </button>
      </div>
    )}

    {related.length > 0 && (
      <div class="faq-related-rail__group">
        <span class="faq-related-rail__heading">Verwandte Mythen</span>
        <ul class="faq-related-rail__list">
          {related.map((m) => (
            <li>
              <button
                type="button"
                class="faq-related-rail__link faq-myth-link"
                data-faq-myth-id={m.id}
                aria-haspopup="dialog"
              >
                {m.title}
              </button>
            </li>
          ))}
        </ul>
      </div>
    )}

    {dashboard.length > 0 && (
      <div class="faq-related-rail__group">
        <span class="faq-related-rail__heading">Daten</span>
        <ul class="faq-related-rail__list">
          {dashboard.map((d) => (
            <li>
              <a href={d.url} class="faq-related-rail__link">
                {d.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
)}
