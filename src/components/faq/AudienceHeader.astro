---
import Markdoc from "@markdoc/markdoc";
import type { FaqAudienceMeta } from "@lib/faq";

interface Props {
  audience: FaqAudienceMeta;
  questionCount: number;
}

const { audience, questionCount } = Astro.props;

// Render the optional intro note as Markdown for inline links.
let introNoteHtml = "";
if (audience.introNote) {
  introNoteHtml = Markdoc.renderers.html(
    Markdoc.transform(Markdoc.parse(audience.introNote)),
  );
}

const accent = audience.accentColor;
---

<header class="faq-audience-header" style={`--audience-accent: ${accent}`}>
  <div class="faq-audience-header__bar">
    <nav class="faq-audience-header__crumbs" aria-label="Brotkrumen">
      <a href="/meine-interessen/">Meine Interessen</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{audience.cardLabel}</span>
    </nav>
    <span
      class="faq-audience-header__count"
      aria-label={`${questionCount} ${questionCount === 1 ? "Frage" : "Fragen"}`}
    >
      {questionCount}
      {questionCount === 1 ? "Frage" : "Fragen"}
    </span>
  </div>

  <h1 class="faq-audience-header__title">
    <span class="faq-audience-header__emoji" aria-hidden="true"
      >{audience.emoji}</span
    >
    Deine Perspektive. Deine Fragen.
  </h1>
  <p class="faq-audience-header__subtitle">
    Cannabis betrifft uns unterschiedlich. Gezielte Antworten auf Mythen — je
    nach Lebenssituation.
  </p>

  {
    introNoteHtml && (
      <aside class="faq-audience-header__note" set:html={introNoteHtml} />
    )
  }
</header>
