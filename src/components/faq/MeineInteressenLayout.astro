---
/**
 * MeineInteressenLayout — top-tab + white-panel shell for /meine-interessen/.
 *
 * Mirrors the Daten-Explorer layout pattern exactly:
 *   • Page header (h1 + subtitle) above the tab bar
 *   • Chrome-style top tabs (same .tabs-bar / .tab-btn shared primitive)
 *   • White panel (.mi-panel) below the tabs — active tab merges into it
 *   • Accordions inside the panel use the page BG so they contrast against white
 *
 * All structural CSS uses :global() to guarantee application independent of
 * Astro's hash-scoping cache. Component-internal styles (tab icons, etc.) are
 * scoped normally.
 */
import type { FaqAudienceId } from "@lib/faq";
import { AUDIENCE_ICONS_BY_FAQ_ID } from "@lib/icons";

interface Props {
  activeAudience: string;
}

const { activeAudience } = Astro.props;

const AUDIENCES: Array<{ id: FaqAudienceId; label: string }> = [
  { id: "eltern",        label: "Eltern" },
  { id: "jugendliche",   label: "Jugendliche" },
  { id: "konsumierende", label: "Konsumierende" },
  { id: "lehrkraefte",   label: "Lehrkräfte" },
  { id: "fachkraefte",   label: "Fachkräfte" },
];

const resolved = AUDIENCES.map((a) => ({
  ...a,
  Icon: AUDIENCE_ICONS_BY_FAQ_ID[a.id],
  isActive: activeAudience === a.id,
}));

const TITLE_BY_AUDIENCE: Record<string, string> = {
  eltern:        "Fragen für Eltern minderjähriger Kinder",
  jugendliche:   "Deine Fragen rund um Cannabis",
  konsumierende: "Fragen für Konsumierende",
  lehrkraefte:   "Fragen für Lehrkräfte",
  fachkraefte:   "Fragen für Fachkräfte",
};
const pageTitle = TITLE_BY_AUDIENCE[activeAudience] ?? "Meine Interessen";

const isFachkraefte = activeAudience === "fachkraefte";
---

<div class="mi-layout">

  <!-- Page header -->
  <header class="mi-header">
    <h1 class="mi-header__title">{pageTitle}</h1>
    <p class="mi-header__subtitle">
      Wähle deine Perspektive und erhalte gezielte Antworten auf Cannabis-Mythen&nbsp;—
      zugeschnitten auf deine Lebenssituation.
    </p>
  </header>

  <!-- Audience tab bar — scrollable, same Chrome-tab style as Daten-Explorer -->
  <div class="mi-tab-bar">
    <div class="tabs-bar" role="tablist" aria-label="Zielgruppe wählen">
      {resolved.map((item) => (
        <a
          href={`/meine-interessen/${item.id}/`}
          class:list={["tab-btn", { "active": item.isActive }]}
          role="tab"
          aria-current={item.isActive ? "page" : undefined}
          aria-selected={item.isActive ? "true" : "false"}
        >
          <span class="mi-tab-icon" aria-hidden="true">
            <item.Icon size={15} />
          </span>
          <span class="mi-tab-label">{item.label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- White panel — border-top omitted so active tab merges flush into it -->
  <div class="mi-panel">
    {isFachkraefte && (
      <p class="mi-hinweis">
        <strong>Hinweis:</strong> Schulkontext-spezifische Fragen finden Sie unter{' '}
        <a href="/meine-interessen/lehrkraefte/">Lehrkräfte</a>.
      </p>
    )}
    <div class="mi-questions">
      <slot />
    </div>
  </div>

</div>

<style>
/* ══════════════════════════════════════════════════════════════════════
   GLOBAL layout rules — :global() so they always apply regardless of
   Astro's hash-based CSS scoping. Mirrors how dashboard.css handles
   main:has(.carm-explorer) but scoped to body.mi-page.
   ══════════════════════════════════════════════════════════════════════ */

:global(body.mi-page) {
  background-color: #faf9f5;
}

:global(body.mi-page main) {
  max-width: none !important;
  margin: 0 !important;
  padding-left: 0 !important;
  padding-right: 0 !important;
  padding-bottom: 0 !important;
  min-height: unset !important;
}

:global(.mi-layout) {
  display: flex !important;
  flex-direction: column !important;
  width: 100%;
  max-width: 900px;
  margin: 0 auto;
  padding: 0 24px 80px;
  box-sizing: border-box;

  --color-surface: #ffffff;
  --color-bg-subtle: #eeeee9;
  --color-border-soft: rgba(191, 201, 193, 0.35);
  --color-border: rgba(191, 201, 193, 0.5);
  --radius-lg: 16px;
  --shadow-chip: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
}

:global(.mi-layout .mi-header) {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 28px;
  padding-top: 16px;
}

:global(.mi-layout .mi-header__title) {
  font-size: 40px;
  font-weight: 800;
  line-height: 48px;
  color: var(--color-accent, #2d6a4f);
  letter-spacing: -0.5px;
  margin: 0;
}

:global(.mi-layout .mi-header__subtitle) {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.7;
  color: #404943;
  margin: 0;
}

:global(.mi-layout .mi-tab-bar) {
  display: flex;
  align-items: flex-end;
  position: relative;
  z-index: 1;
}

:global(.mi-layout .mi-tab-bar .tabs-bar) {
  gap: 16px;
  width: 100%;
  justify-content: center;
  border-bottom: 0px;
}

:global(.mi-layout .mi-tab-bar .tab-btn) {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 9px 18px;
  background: var(--color-bg-subtle, #eeeee9);
  text-decoration: none;
  border-radius: 16px 16px 0 0;
}

:global(.mi-layout .mi-tab-bar .tab-btn.active) {
  background: var(--color-surface, #ffffff);
  border: none;
  border-radius: 16px 16px 0 0;
}

:global(.mi-layout .mi-panel) {
  display: flex;
  flex-direction: column;
  gap: 0;
  background: var(--color-surface, #ffffff);
  border: 1px solid var(--color-border-soft, rgba(191, 201, 193, 0.35));
  border-top: none;
  border-radius: var(--radius-lg, 16px);
  box-shadow: var(--shadow-chip, 0 4px 20px -2px rgba(0, 0, 0, 0.05));
  padding: 32px;
}

:global(.mi-layout .mi-hinweis) {
  font-size: 14.5px;
  line-height: 1.55;
  color: #2f3a33;
  margin: 0 0 24px;
  padding: 12px 16px;
  background: rgba(233, 240, 225, 0.55);
  border-left: 3px solid #0f5238;
  border-radius: 0 10px 10px 0;
}

:global(.mi-layout .mi-hinweis strong) { font-weight: 700; color: #0f5238; }

:global(.mi-layout .mi-hinweis a) {
  color: #0f5238;
  font-weight: 600;
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 2px;
}

:global(.mi-layout .mi-questions) {
  display: flex;
  flex-direction: column;
}

:global(.mi-layout .faq-audience-questions) {
  gap: 24px;
}

/* ── Audience page overrides ───────────────────────────────────────── */
:global(.mi-layout .faq-audience-page)       { max-width: none; margin: 0; }
:global(.mi-layout .faq-audience-header)     { display: none; }
:global(.mi-layout .faq-toc)                 { display: none; }
:global(.mi-layout .faq-audience-page__footer) { display: none; }
:global(.mi-layout .faq-audience-questions)  { margin-top: 0; }

/* ── FAQ accordion cards ───────────────────────────────────────────── */
:global(.mi-layout .faq-question) {
  background: #faf9f5;
  border: 1px solid rgba(191, 201, 193, 0.2);
  border-radius: 24px;
  box-shadow: none;
}

:global(.mi-layout .faq-question:hover) {
  border-color: rgba(191, 201, 193, 0.5);
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.05);
}

:global(.mi-layout .faq-question__summary) {
  display: grid;
  grid-template-columns: 32px 1fr auto auto;
  align-items: center;
  gap: 0 24px;
  padding: 24px;
}

:global(.mi-layout .faq-question__details[open] > .faq-question__summary) {
  border-bottom: 1px solid rgba(191, 201, 193, 0.3);
}

:global(.mi-layout .faq-question__index) {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 700;
  color: #bfc9c1;
  line-height: 30px;
  min-width: unset;
}

:global(.mi-layout .faq-question__heading) {
  font-size: 18px;
  font-weight: 400;
  color: #1a1c1a;
  line-height: 27px;
  margin: 0;
}

:global(.mi-layout .faq-question__chevron) {
  font-size: 0;
  line-height: 0;
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23404943' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 12px 8px;
}

:global(.mi-layout .faq-question__body) {
  padding: 0 24px 25px;
  padding-left: 80px;
}

:global(.mi-layout .faq-question__lead) {
  font-size: 16px;
  font-weight: 700;
  color: #1a1c1a;
  line-height: 1.7;
  margin-bottom: 15px;
}

:global(.mi-layout .faq-question__answer),
:global(.mi-layout .faq-question__answer p) {
  font-size: 16px;
  font-weight: 400;
  color: #404943;
  line-height: 1.7;
}

/* ── Scoped: tab icon ──────────────────────────────────────────────── */
.mi-tab-icon {
  display: inline-flex;
  align-items: center;
  flex: none;
  opacity: 0.65;
}

:global(.mi-layout .mi-tab-bar .tab-btn.active) .mi-tab-icon {
  opacity: 1;
  color: var(--color-accent, #2d6a4f);
}

/* ── Responsive ────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  :global(.mi-layout .mi-tab-bar) {
    position: sticky;
    top: calc(var(--header-height, 60px) - 1px);
    z-index: 50;
    background: #faf9f5;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  :global(.mi-layout .mi-tab-bar)::-webkit-scrollbar { display: none; }

  :global(.mi-layout .mi-panel) { padding: 20px 16px 24px; }
}

@media (max-width: 640px) {
  :global(.mi-layout) { padding-left: 16px; padding-right: 16px; }
  :global(.mi-layout .mi-header__title) { font-size: 30px; line-height: 1.15; }

  :global(.mi-layout .mi-tab-bar .tab-btn:not(.active) .mi-tab-label) {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
  :global(.mi-layout .mi-tab-bar .tab-btn:not(.active)) { padding: 9px 14px; }
}
</style>
