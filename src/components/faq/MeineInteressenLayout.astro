---
/**
 * MeineInteressenLayout — sidebar + content shell for all /meine-interessen/{slug}/ pages.
 *
 * Desktop (≥1024px): fixed 280px left sidebar with the 5 audience categories.
 * Tablet / mobile (<1024px): horizontal sticky pill rail at the top of the
 * content area, scrollable when it overflows. Both surfaces use the same
 * AUDIENCES list, the same active-state colour, and the same audience icons.
 *
 * The active item is highlighted from the `activeAudience` prop. All FAQ
 * accordion mechanics, content, verdict pills, and routing are unchanged.
 *
 * Backgrounds: the cream surface tone for /meine-interessen/ is painted on
 * <body.mi-page> so the global `.dot-texture` pattern remains visible
 * underneath. The layout itself is transparent so the dotted background
 * shows through the sidebar area and the content area uniformly.
 */
import type { FaqAudienceId } from "@lib/faq";
import { AUDIENCE_ICONS_BY_FAQ_ID } from "@lib/icons";

interface Props {
  activeAudience: string;
}

const { activeAudience } = Astro.props;

const AUDIENCES: Array<{ id: FaqAudienceId; label: string }> = [
  { id: "eltern",        label: "Eltern" },
  { id: "jugendliche",   label: "Jugendliche" },
  { id: "konsumierende", label: "Konsumierende" },
  { id: "lehrkraefte",   label: "Lehrkräfte" },
  { id: "fachkraefte",   label: "Fachkräfte" },
];

const resolved = AUDIENCES.map((a) => ({
  ...a,
  Icon: AUDIENCE_ICONS_BY_FAQ_ID[a.id],
  isActive: activeAudience === a.id,
}));

// Per-audience page title shown above the question accordions.
// EN gloss: "Questions for parents of underage children" / "Your questions
// about cannabis" / "Questions for {Consumers|Teachers|Professionals}".
const TITLE_BY_AUDIENCE: Record<string, string> = {
  eltern:        "Fragen für Eltern minderjähriger Kinder",
  jugendliche:   "Deine Fragen rund um Cannabis",
  konsumierende: "Fragen für Konsumierende",
  lehrkraefte:   "Fragen für Lehrkräfte",
  fachkraefte:   "Fragen für Fachkräfte",
};
const pageTitle = TITLE_BY_AUDIENCE[activeAudience] ?? "Meine Interessen";

// Fachkräfte page carries one extra Sie-form note pointing professionals
// with school-context questions over to the Lehrkräfte page. Only the
// word "Lehrkräfte" is the link, not the full sentence.
const isFachkraefte = activeAudience === "fachkraefte";
---

<div class="mi-layout">

  <!-- Desktop sidebar -->
  <aside class="mi-sidebar" aria-label="Zielgruppe wählen">
    <nav class="mi-sidebar__nav">
      {resolved.map((item) => (
        <a
          href={`/meine-interessen/${item.id}/`}
          class:list={["mi-nav-item", { "mi-nav-item--active": item.isActive }]}
          aria-current={item.isActive ? "page" : undefined}
        >
          {item.isActive && <span class="mi-nav-item__dot" aria-hidden="true" />}
          <span class="mi-nav-item__label">{item.label}</span>
          <span class="mi-nav-item__icon" aria-hidden="true">
            <item.Icon size={20} />
          </span>
        </a>
      ))}
    </nav>
  </aside>

  <!-- Right content panel -->
  <div class="mi-content">
    <div class="mi-content__inner">

      <!-- Page header -->
      <header class="mi-header">
        <h1 class="mi-header__title">{pageTitle}</h1>
        {isFachkraefte && (
          <p class="mi-header__hinweis">
            <strong>Hinweis:</strong> Schulkontext-spezifische Fragen finden Sie unter{' '}
            <a href="/meine-interessen/lehrkraefte/">Lehrkräfte</a>.
          </p>
        )}
        <p class="mi-header__subtitle">
          Wähle deine Perspektive und erhalte gezielte Antworten auf Cannabis-Mythen&nbsp;—
          zugeschnitten auf deine Lebenssituation.
        </p>
      </header>

      <!-- Tablet / mobile audience rail (visible <1024px) -->
      <nav class="mi-rail" aria-label="Zielgruppe wählen">
        <div class="mi-rail__track" role="tablist">
          {resolved.map((item) => (
            <a
              href={`/meine-interessen/${item.id}/`}
              class:list={["mi-rail__pill", { "mi-rail__pill--active": item.isActive }]}
              aria-current={item.isActive ? "page" : undefined}
              role="tab"
              aria-selected={item.isActive ? "true" : "false"}
            >
              <span class="mi-rail__pill-icon" aria-hidden="true">
                <item.Icon size={18} />
              </span>
              <span class="mi-rail__pill-label">{item.label}</span>
            </a>
          ))}
        </div>
        <span class="mi-rail__fade mi-rail__fade--right" aria-hidden="true"></span>
      </nav>

      <!-- Accordion questions (slotted from the audience page) -->
      <div class="mi-questions">
        <slot />
      </div>

    </div>
  </div>
</div>

<style>
/* ── Layout wrapper ──────────────────────────────────────────────────── */
.mi-layout {
  position: relative;
  display: flex;
  width: 100%;
  min-height: calc(100vh - var(--header-height, 140px));
  /* Transparent — the page's dot-textured cream body shows through. */
  background: transparent;
}

/* Full-height vertical divider between sidebar and content. The sidebar
   itself only renders the divider while it's in view (fixed); this
   pseudo-element makes the line span the entire viewport height
   including the header strip and any over-scroll, so it never "cuts".
   Hidden on tablet/mobile where the sidebar is replaced by the rail. */
.mi-layout::before {
  content: "";
  position: fixed;
  top: 0;
  bottom: 0;
  left: 280px;
  width: 1px;
  background: rgba(191, 201, 193, 0.5);
  z-index: 49;
  pointer-events: none;
}

/* ── Desktop sidebar ─────────────────────────────────────────────────── */
.mi-sidebar {
  position: fixed;
  top: var(--header-height, 140px);
  left: 0;
  bottom: 0;
  width: 280px;
  /* Transparent — dot-textured body shows through here too. */
  background: transparent;
  overflow-y: auto;
  overflow-x: hidden;
  z-index: 50;
}

.mi-sidebar__nav {
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 24px;
}

/* ── Sidebar nav items ───────────────────────────────────────────────── */
.mi-nav-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding-left: 48px;
  padding-right: 32px;
  background: #ffffff;
  border-radius: 0 16px 16px 0;
  margin-left: -10px;
  text-decoration: none;
  color: #404943;
  transition: background 0.15s;
}

.mi-nav-item:hover { background: #f0f4ee; }

.mi-nav-item--active {
  background: #e9f0e1;
  color: #0f5238;
}

.mi-nav-item__label {
  font-size: 14px;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
}

.mi-nav-item--active .mi-nav-item__label {
  font-weight: 700;
  color: #0f5238;
}

.mi-nav-item__icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #404943;
  opacity: 0.65;
}

.mi-nav-item--active .mi-nav-item__icon {
  color: #0f5238;
  opacity: 1;
}

/* Active indicator: 4 × 4 px square, 8px gap to the label.
   Label starts at padding-left 48px, dot is 4px wide → left = 48 - 8 - 4 = 36px. */
.mi-nav-item__dot {
  position: absolute;
  left: 36px;
  top: 50%;
  transform: translateY(-50%);
  width: 4px;
  height: 4px;
  background: #0f5238;
  border-radius: 2px;
  display: block;
}

/* ── Right content panel ─────────────────────────────────────────────── */
.mi-content {
  margin-left: 280px;
  flex: 1;
  padding-top: 56px;
  padding-bottom: 80px;
}

.mi-content__inner {
  max-width: 740px;
  margin-left: 130px;
}

/* ── Page header ─────────────────────────────────────────────────────── */
.mi-header {
  display: flex;
  flex-direction: column;
  gap: 15px;
  margin-bottom: 54px;
}

.mi-header__title {
  font-size: 40px;
  font-weight: 800;
  line-height: 48px;
  color: #1a1c1a;
  letter-spacing: -0.5px;
  margin: 0;
}

.mi-header__subtitle {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.7;
  color: #404943;
  margin: 0;
}

/* Fachkräfte-only cross-reference. Rendered as a small inset card with a
   green accent stripe so it reads as a guiding note, not a content block. */
.mi-header__hinweis {
  font-size: 14.5px;
  font-weight: 400;
  line-height: 1.55;
  color: #2f3a33;
  margin: 0;
  padding: 12px 16px;
  background: rgba(233, 240, 225, 0.55);
  border-left: 3px solid #0f5238;
  border-radius: 0 10px 10px 0;
}

.mi-header__hinweis strong {
  font-weight: 700;
  color: #0f5238;
  letter-spacing: 0.01em;
}

.mi-header__hinweis a {
  color: #0f5238;
  font-weight: 600;
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 2px;
  transition: color 0.15s;
}

.mi-header__hinweis a:hover {
  color: #0b3d2a;
  text-decoration-thickness: 2px;
}

/* ── Tablet / mobile audience rail ───────────────────────────────────── */
/* Hidden on desktop — desktop uses the fixed sidebar. */
.mi-rail { display: none; }

/* ── Questions slot wrapper ──────────────────────────────────────────── */
.mi-questions {
  /* transparent — gap handled by .faq-audience-questions inside */
}

/* ═══════════════════════════════════════════════════════════════════════
   Global overrides — scoped to .mi-layout, cannot bleed elsewhere.
   Only layout, spacing, card shape. Verdict pills: zero changes.
   ═══════════════════════════════════════════════════════════════════════ */

/* Paint the page's cream surface tone on <body> so the global
   `.dot-texture` background-image (set on body.dot-texture) sits on top
   of the same warm colour the sidebar previously painted on its own. */
:global(body.mi-page) {
  background-color: #faf9f5;
}

/* Full-width <main> on meine-interessen pages */
:global(body.mi-page main) {
  max-width: none;
  margin: 0;
  padding-left: 0;
  padding-right: 0;
  padding-bottom: 0;
  min-height: unset;
}

/* Remove built-in centering from the audience page article */
:global(.mi-layout .faq-audience-page) {
  max-width: none;
  margin: 0;
}

/* Hide elements replaced by the sidebar */
:global(.mi-layout .faq-audience-header)       { display: none; }
:global(.mi-layout .faq-toc)                   { display: none; }
:global(.mi-layout .faq-audience-page__footer) { display: none; }

/* Remove top margin that used to push questions away from the header */
:global(.mi-layout .faq-audience-questions) { margin-top: 0; }

/* ── FAQ accordion cards: shape + shadow only ────────────────────────── */
:global(.mi-layout .faq-question) {
  background: #ffffff;
  border: 1px solid rgba(191, 201, 193, 0.1);
  border-radius: 24px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

:global(.mi-layout .faq-question:hover) {
  border-color: rgba(191, 201, 193, 0.35);
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.07);
}

/* Summary row: 24px padding, 24px column gap */
:global(.mi-layout .faq-question__summary) {
  display: grid;
  grid-template-columns: 32px 1fr auto auto;
  align-items: center;
  gap: 0 24px;
  padding: 24px;
}

:global(.mi-layout .faq-question__details[open] > .faq-question__summary) {
  border-bottom: 1px solid rgba(191, 201, 193, 0.3);
}

/* Number: large muted counter */
:global(.mi-layout .faq-question__index) {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 700;
  color: #bfc9c1;
  line-height: 30px;
  min-width: unset;
}

/* Question heading */
:global(.mi-layout .faq-question__heading) {
  font-size: 18px;
  font-weight: 400;
  color: #1a1c1a;
  line-height: 27px;
  margin: 0;
}

/* Chevron: hide ▾ text, show SVG arrow via background-image */
:global(.mi-layout .faq-question__chevron) {
  font-size: 0;
  line-height: 0;
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l5 5 5-5' stroke='%23404943' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 12px 8px;
}

/* Body: left-aligned with question text (24 outer + 32 number + 24 gap = 80px) */
:global(.mi-layout .faq-question__body) {
  padding: 0 24px 25px;
  padding-left: 80px;
}

/* Lead answer */
:global(.mi-layout .faq-question__lead) {
  font-size: 16px;
  font-weight: 700;
  color: #1a1c1a;
  line-height: 1.7;
  margin-bottom: 15px;
}

/* Answer body text */
:global(.mi-layout .faq-question__answer),
:global(.mi-layout .faq-question__answer p) {
  font-size: 16px;
  font-weight: 400;
  color: #404943;
  line-height: 1.7;
}

/* ── Tablet / mobile: collapse sidebar → top rail ────────────────────── */
@media (max-width: 1023px) {
  /* Hide desktop sidebar + its full-height divider line. */
  .mi-sidebar { display: none; }
  .mi-layout::before { display: none; }

  /* Content panel reflows to full width. */
  .mi-content {
    margin-left: 0;
    padding-top: 24px;
    padding-left: var(--space-lg, 1.5rem);
    padding-right: var(--space-lg, 1.5rem);
  }
  .mi-content__inner { margin-left: 0; max-width: none; }

  .mi-header { margin-bottom: 24px; }
  .mi-header__title { font-size: 32px; line-height: 1.15; }

  /* Pill rail: sticky right under the floating nav, scrolls horizontally
     when the five pills overflow. The fade gradient on the right edge
     hints at scrollability without a visible scrollbar. */
  .mi-rail {
    display: block;
    position: sticky;
    top: calc(var(--header-height, 140px) - 16px);
    z-index: 30;
    margin: 0 calc(var(--space-lg, 1.5rem) * -1) 24px;
    padding: 8px 0;
    background:
      linear-gradient(
        to bottom,
        rgba(250, 249, 245, 0.96) 0%,
        rgba(250, 249, 245, 0.96) 70%,
        rgba(250, 249, 245, 0) 100%
      );
    backdrop-filter: saturate(140%) blur(6px);
    -webkit-backdrop-filter: saturate(140%) blur(6px);
  }

  .mi-rail__track {
    display: flex;
    gap: 8px;
    padding: 4px var(--space-lg, 1.5rem);
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .mi-rail__track::-webkit-scrollbar { display: none; }

  .mi-rail__pill {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 38px;
    padding: 0 16px;
    border-radius: 999px;
    background: #ffffff;
    border: 1px solid rgba(191, 201, 193, 0.45);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    text-decoration: none;
    color: #404943;
    font-size: 14px;
    font-weight: 600;
    line-height: 1;
    white-space: nowrap;
    scroll-snap-align: start;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.1s;
  }

  .mi-rail__pill:hover { background: #f0f4ee; }
  .mi-rail__pill:active { transform: translateY(1px); }

  .mi-rail__pill--active {
    background: #e9f0e1;
    color: #0f5238;
    border-color: rgba(15, 82, 56, 0.35);
    font-weight: 700;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.05),
      inset 0 0 0 1px rgba(15, 82, 56, 0.15);
  }

  .mi-rail__pill-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: currentColor;
    opacity: 0.7;
  }
  .mi-rail__pill--active .mi-rail__pill-icon { opacity: 1; }

  /* Right-edge fade hinting at horizontal scroll. Sits inside the rail
     so it tracks the rail's sticky position. */
  .mi-rail__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 32px;
    pointer-events: none;
  }
  .mi-rail__fade--right {
    right: 0;
    background: linear-gradient(
      to right,
      rgba(250, 249, 245, 0) 0%,
      rgba(250, 249, 245, 0.95) 100%
    );
  }
}

/* Extra-tight phone widths: drop the label on inactive pills to save room
   (active pill keeps its label for orientation). */
@media (max-width: 460px) {
  .mi-rail__pill {
    padding: 0 12px;
    gap: 6px;
  }
  .mi-rail__pill:not(.mi-rail__pill--active) .mi-rail__pill-label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .mi-rail__pill:not(.mi-rail__pill--active) {
    width: 38px;
    padding: 0;
    justify-content: center;
  }
}
</style>
