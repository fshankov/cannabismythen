---
import Markdoc, { type Node } from "@markdoc/markdoc";
import { faqMarkdocConfig } from "@lib/markdoc/faq-nodes";
import {
  loadMythPopupData,
  type FaqMythPopupData,
  type FaqQuestion,
} from "@lib/faq";
import FaqRelatedRail from "./FaqRelatedRail.astro";
import HelplineBox from "./HelplineBox.astro";

interface Props {
  question: FaqQuestion;
  /** Whether this <details> should default to open. */
  open?: boolean;
  /** Index in the audience listing, used for the visible numbering. */
  index: number;
  /** Popup data, hoisted to the page level so the helper is invoked once
   *  per render instead of once per FaqQuestion (the page typically has
   *  15 of these; before hoisting each one re-parsed all 42 myth .mdoc
   *  files, costing ~1s per call in dev). When omitted we fall back to
   *  loading it ourselves — the helper is now cached so the cost is
   *  one-time per dev-server process. */
  popupData?: FaqMythPopupData;
}

const {
  question,
  open = false,
  index,
  popupData: popupDataProp,
} = Astro.props;

const popupData = popupDataProp ?? (await loadMythPopupData());
const { resolveTitlesInHtml, mythIndex } = popupData;

const { node } = await question.answer();
const rawHtml = Markdoc.renderers.html(
  Markdoc.transform(node as Node, faqMarkdocConfig as any),
);
// Resolve the {% factsheet-link %} placeholders into actual myth statements.
const html = resolveTitlesInHtml(rawHtml);

const id = `faq-${question.slug}`;
---

<article id={id} class="faq-question" data-classification={question.classification}>
  <!-- name= makes the questions an exclusive (single-open) accordion natively. -->
  <details class="faq-question__details" name="faq-accordion" open={open}>
    <summary class="faq-question__summary">
      <span class="faq-question__index" aria-hidden="true">{String(index).padStart(2, "0")}</span>
      <h2 class="faq-question__heading">{question.questionLong}</h2>
      <span class="faq-question__chevron" aria-hidden="true">▾</span>
    </summary>

    <div class="faq-question__body">
      {question.leadAnswer && (
        <p class="faq-question__lead">{question.leadAnswer}</p>
      )}

      <div class="faq-question__answer" set:html={html} />

      <FaqRelatedRail question={question} mythIndex={mythIndex} />

      {question.helpline && question.helpline.url && (
        <HelplineBox helpline={question.helpline} variant="inline" />
      )}

      {/* Permalink removed per ISD request (Asana 1215623512246223) — the
          per-question deep link wasn't needed. The article still carries
          id={id} so existing #faq-<slug> anchors keep working. */}

      <button type="button" class="faq-collapse" aria-label="Frage einklappen">
        <span class="faq-collapse__arrow" aria-hidden="true">▴</span>
      </button>
    </div>
  </details>
</article>

<script>
  // FAQ accordion behaviour, attached once globally (Astro hoists & dedupes
  // this module script across all <FaqQuestion> instances on the page):
  //   1. The full-width fold bar at the bottom of an open question collapses it
  //      and scrolls its summary back into view.
  //   2. Single-open fallback: opening one question closes any open sibling in
  //      the same questions container — a safety net for browsers without
  //      <details name> exclusive-accordion support.
  (() => {
    if ((window as any).__faqAccordionInit) return;
    (window as any).__faqAccordionInit = true;

    // 1) Fold bar → collapse + scroll summary into view.
    document.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement | null)?.closest(".faq-collapse");
      if (!btn) return;
      const details = btn.closest("details.faq-question__details") as HTMLDetailsElement | null;
      if (!details) return;
      details.open = false;
      const summary = details.querySelector(".faq-question__summary");
      if (summary) {
        (summary as HTMLElement).scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    });

    // 2) On open: close any open sibling (single-open) AND bring the opened
    //    question's title to the top of the view, so the answer starts right
    //    there instead of leaving the viewport on the question that just
    //    collapsed. toggle doesn't bubble → bind per element.
    const all = Array.from(
      document.querySelectorAll<HTMLDetailsElement>("details.faq-question__details"),
    );
    for (const d of all) {
      d.addEventListener("toggle", () => {
        if (!d.open) return;
        for (const other of all) {
          if (other !== d && other.open) other.open = false;
        }
        // Scroll after the sibling-close reflow so positions are final.
        // Manual scrollTo is more reliable than scrollIntoView + scroll-padding
        // across browsers: put the card title just below the sticky nav.
        const article = d.closest(".faq-question");
        if (article) {
          requestAnimationFrame(() => {
            const rect = (article as HTMLElement).getBoundingClientRect();
            const headerHeight =
              parseFloat(
                getComputedStyle(document.documentElement)
                  .getPropertyValue("--header-height")
              ) || 80;
            const gap = 16;
            const targetY = window.scrollY + rect.top - headerHeight - gap;
            window.scrollTo({ top: targetY, behavior: "smooth" });
          });
        }
      });
    }
  })();
</script>
