---
import { CLASSIFICATION_LABEL, type FaqClassification } from "@lib/faq";
import VerdictPill from "@components/shared/VerdictPill";
import type { CorrectnessClass } from "@/lib/dashboard/types";

interface Props {
  classification: FaqClassification;
  customLabel?: string;
  size?: "sm" | "md";
}

const { classification, customLabel, size = "md" } = Astro.props;

const label = customLabel?.trim() || CLASSIFICATION_LABEL[classification];

// FAQ's "n_a" (meta questions) + "keine_aussage" both render as the
// no-classification verdict in the .pill system.
const verdict: CorrectnessClass =
  classification === "n_a" || classification === "keine_aussage"
    ? "no_classification"
    : classification;
---

<VerdictPill
  verdict={verdict}
  label={label}
  size={size}
  className={`faq-verdict faq-verdict--${size}`}
  aria-label={`Wissenschaftliche Einordnung: ${label}`}
/>
