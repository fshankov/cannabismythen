---
import { CORRECTNESS_COLORS } from "@lib/dashboard/colors";
import type { CorrectnessClass } from "@lib/dashboard/types";
import "../../styles/home-quiz-hook.css";

type VerdictKey = "falsch" | "eher_falsch" | "eher_richtig" | "richtig";

export interface Props {
  eyebrow: string;
  headline: string;
  subhead: string;
  sampleMythText: string;
  sampleMythClassification: VerdictKey;
  primaryCtaLabel: string;
  primaryCtaUrl: string;
  secondaryCtaLabel: string;
  secondaryCtaUrl: string;
}

const {
  eyebrow,
  headline,
  subhead,
  sampleMythText,
  sampleMythClassification,
  primaryCtaLabel,
  primaryCtaUrl,
  secondaryCtaLabel,
  secondaryCtaUrl,
} = Astro.props;

const verdictButtons: Array<{ key: VerdictKey; label: string }> = [
  { key: "falsch", label: "Falsch" },
  { key: "eher_falsch", label: "Eher falsch" },
  { key: "eher_richtig", label: "Eher richtig" },
  { key: "richtig", label: "Richtig" },
];
---

<section class="quiz-hook" aria-labelledby="quiz-hook-heading">
  <div class="quiz-hook__inner">
    <div class="quiz-hook__copy">
      <p class="quiz-hook__eyebrow">{eyebrow}</p>
      <h2 id="quiz-hook-heading" class="quiz-hook__headline">{headline}</h2>
      <p class="quiz-hook__subhead">{subhead}</p>

      <div class="quiz-hook__ctas">
        <a href={primaryCtaUrl} class="quiz-hook__primary">
          {primaryCtaLabel}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={secondaryCtaUrl} class="quiz-hook__secondary">
          {secondaryCtaLabel}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Non-interactive quiz-card preview — teaser only, real quiz lives at /quiz/ -->
    <div class="quiz-hook__preview" aria-hidden="true">
      <div class="quiz-hook__preview-card">
        <div class="quiz-hook__preview-eyebrow">
          <span class="quiz-hook__preview-dot"></span>
          Frage 1 von 10
        </div>
        <p class="quiz-hook__preview-statement">{sampleMythText}</p>
        <div class="quiz-hook__preview-buttons">
          {verdictButtons.map((b) => {
            const isAnswer = b.key === sampleMythClassification;
            const color = CORRECTNESS_COLORS[b.key as CorrectnessClass];
            return (
              <div
                class={`quiz-hook__preview-button ${isAnswer ? "is-answer" : ""}`}
                style={isAnswer ? `border-color:${color}; color:${color};` : ""}
              >
                {b.label}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>

