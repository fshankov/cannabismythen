---
import "../../styles/home-project-strip.css";

export interface ProjectLink {
  label: string;
  url: string;
}

export interface Props {
  credit: string;
  links: ReadonlyArray<ProjectLink>;
}

const { credit, links } = Astro.props;
---

<aside class="project-strip" aria-label="Projekt-Hintergrund">
  <div class="project-strip__inner">
    <p class="project-strip__credit">{credit}</p>

    {links.length > 0 && (
      <ul class="project-strip__links">
        {links.map((link) => (
          <li>
            <a class="project-strip__link" href={link.url}>
              {link.label}
              <span aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</aside>
