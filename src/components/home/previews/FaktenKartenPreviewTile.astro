---
import FaktenKartenPreviewDeck from "./FaktenKartenPreviewDeck";

export interface PreviewMyth {
  text: string;
  classification: string;
  /** Myth taxonomy group — drives the card-front category footer. */
  categoryGroup?: string;
  /** Optional; no longer rendered on the card front (kept for back-compat). */
  summary?: string;
}

export interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  targetUrl: string;
  previewMyths: ReadonlyArray<PreviewMyth>;
}

const { title, description, ctaLabel, targetUrl, previewMyths } = Astro.props;

const deckMyths = previewMyths.map((m) => ({
  text: m.text,
  classification: m.classification,
  categoryGroup: m.categoryGroup ?? "",
}));
---

<a class="path-tile path-tile--karten" href={targetUrl}>
  <div class="path-tile__preview">
    <FaktenKartenPreviewDeck myths={deckMyths} client:visible />
  </div>

  <div class="path-tile__body">
    <h3 class="path-tile__title">
      {title}
      <span class="path-tile__title-arrow" aria-hidden="true">→</span>
    </h3>
    <p class="path-tile__description">{description}</p>
  </div>
</a>
