---
import MeineInteressenPreviewDeck from "./MeineInteressenPreviewDeck";
import type { AudienceDeckEntry } from "./MeineInteressenPreviewDeck";

/* The chip / deck-entry shape stays exported under the old name so
   `src/pages/index.astro` doesn't have to chase the rename. */
export type AudienceChip = AudienceDeckEntry;

export interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  targetUrl: string;
  chips: ReadonlyArray<AudienceChip>;
}

const { title, description, ctaLabel, targetUrl, chips } = Astro.props;
---

<a class="path-tile path-tile--meine" href={targetUrl}>
  <div class="path-tile__preview">
    <MeineInteressenPreviewDeck audiences={chips} client:visible />
  </div>

  <div class="path-tile__body">
    <h3 class="path-tile__title">
      {title}
      <span class="path-tile__title-arrow" aria-hidden="true">→</span>
    </h3>
    <p class="path-tile__description">{description}</p>
    <p class="path-tile__cta">{ctaLabel}</p>
  </div>
</a>
