---
import {
  AUDIENCE_ICONS_BY_FAQ_ID,
  AUDIENCE_COLOR_VAR_BY_FAQ_ID,
  type FaqAudienceId,
} from "@lib/icons";

export interface AudienceChip {
  audienceId: string;
  cardLabel: string;
}

export interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  targetUrl: string;
  chips: ReadonlyArray<AudienceChip>;
}

const { title, description, ctaLabel, targetUrl, chips } = Astro.props;
---

<a class="path-tile path-tile--meine" href={targetUrl}>
  <div class="path-tile__preview">
    <div class="meine-preview" aria-hidden="true">
      {chips.map((chip) => {
        const audienceId = chip.audienceId as FaqAudienceId;
        const Icon = AUDIENCE_ICONS_BY_FAQ_ID[audienceId];
        const accentVar = AUDIENCE_COLOR_VAR_BY_FAQ_ID[audienceId];
        return (
          <span
            class="meine-preview__chip"
            style={`--audience-color: var(${accentVar})`}
          >
            {Icon && (
              <Icon size={16} className="meine-preview__icon" aria-hidden="true" />
            )}
            <span class="meine-preview__label">{chip.cardLabel}</span>
          </span>
        );
      })}
    </div>
  </div>

  <div class="path-tile__body">
    <h3 class="path-tile__title">
      {title}
      <span class="path-tile__title-arrow" aria-hidden="true">→</span>
    </h3>
    <p class="path-tile__description">{description}</p>
    <p class="path-tile__cta">{ctaLabel}</p>
  </div>
</a>
