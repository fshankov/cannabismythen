---
import MeineInteressenPreviewRows from "./MeineInteressenPreviewRows";
import type { AudienceRow } from "./MeineInteressenPreviewRows";

/* The audience shape stays exported under the old name `AudienceChip` so
   `src/pages/index.astro` + FourPathsBlock don't have to chase the rename. */
export type AudienceChip = AudienceRow;

export interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  targetUrl: string;
  chips: ReadonlyArray<AudienceChip>;
}

const { title, description, ctaLabel, targetUrl, chips } = Astro.props;
---

<a class="path-tile path-tile--meine" href={targetUrl}>
  <div class="path-tile__preview">
    <MeineInteressenPreviewRows audiences={chips} />
  </div>

  <div class="path-tile__body">
    <h3 class="path-tile__title">
      {title}
      <span class="path-tile__title-arrow" aria-hidden="true">→</span>
    </h3>
    <p class="path-tile__description">{description}</p>
  </div>
</a>
