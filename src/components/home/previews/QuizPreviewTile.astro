---
import QuizPreviewDeck from "./QuizPreviewDeck";

export interface Props {
  title: string;
  description: string;
  ctaLabel: string;
  targetUrl: string;
}

const { title, description, ctaLabel, targetUrl } = Astro.props;
---

<a class="path-tile path-tile--quiz" href={targetUrl}>
  <div class="path-tile__preview">
    <QuizPreviewDeck client:visible />
  </div>

  <div class="path-tile__body">
    <h3 class="path-tile__title">
      {title}
      <span class="path-tile__title-arrow" aria-hidden="true">→</span>
    </h3>
    <p class="path-tile__description">{description}</p>
    <p class="path-tile__cta">{ctaLabel}</p>
  </div>
</a>
