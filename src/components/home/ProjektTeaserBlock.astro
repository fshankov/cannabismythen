---
import "../../styles/home-projekt-teaser.css";

export interface Props {
  /** Multiline Keystatic field — blank lines separate paragraphs. */
  body: string;
  /** Anchor id so the hero's scroll-down cue can target this block. */
  anchorId?: string;
}

const { body, anchorId = "projekt-teaser" } = Astro.props;

// Blank lines in the multiline `body` field mark paragraph breaks.
const paragraphs = body
  .split(/\n\s*\n/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<section class="projekt-teaser" id={anchorId} aria-label="Über das Projekt" data-reveal>
  <div class="projekt-teaser__inner">
    <div class="projekt-teaser__card">
      <div class="projekt-teaser__body">
        {paragraphs.map((p) => <p class="projekt-teaser__para">{p}</p>)}
      </div>
    </div>
  </div>
</section>
