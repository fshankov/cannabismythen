---
import "../../styles/home-four-paths.css";
import { getVerdictVisual } from "../../lib/fakten-karten/verdict-colors";
import type { CorrectnessClass } from "../../lib/dashboard/types";
import { AUDIENCE_ICONS_BY_FAQ_ID } from "../../lib/icons/lookups";
import type { FaqAudienceId } from "../../lib/icons/lookups";

export interface HookQuote {
  eyebrow: string;
  leadClause: string;
  counterClause: string;
  counterClassification: string;
}

export interface TileBase {
  title: string;
  description: string;
  ctaLabel: string;
  targetUrl: string;
}

/* Quiz tile still carries the legacy sampleX fields in Keystatic; we accept
 * the wider shape and only use the TileBase fields here. */
export interface QuizTileConfig extends TileBase {
  sampleEyebrow?: string;
  sampleMythText?: string;
  sampleMythClassification?: "falsch" | "eher_falsch" | "eher_richtig" | "richtig";
}

export interface Props {
  hookQuote: HookQuote;
  quizTile: QuizTileConfig;
  faktenKartenTile: TileBase;
  datenExplorerTile: TileBase;
  meineInteressenTile: TileBase;
  /** Shortest myth per verdict (built in index.astro) — feeds the Fakten card. */
  previewMyths?: ReadonlyArray<{
    text: string;
    classification: string;
    categoryGroup?: string;
    summary?: string;
  }>;
  /** The five FAQ audiences (id + label) — feeds the Meine-Interessen card. */
  audienceChips?: ReadonlyArray<{ id: FaqAudienceId; label: string }>;
}

const {
  hookQuote,
  quizTile,
  faktenKartenTile,
  datenExplorerTile,
  meineInteressenTile,
  previewMyths = [],
  audienceChips = [],
} = Astro.props;

// Pre-oriented direction arrows (verbatim from the card-bg-arrow SVGs). Inlined
// rather than <img> so `overflow: visible` can show the full arrow — the source
// SVGs draw strokes beyond their own viewBox, which an <img> crops away.
const FAKTEN_ARROWS: Record<string, { viewBox: string; inner: string }> = {
  richtig: {
    viewBox: "0 0 181 186",
    inner: `<path d="M164.999 15.531L-55 15.531" stroke="currentColor" stroke-opacity="0.44" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/><path d="M54.9953 169.529L54.9953 15.5297" stroke="currentColor" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/><path d="M131.999 92.529L54.9996 15.5293L-22.0001 92.529" stroke="currentColor" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  eher_falsch: {
    viewBox: "0 0 188 280",
    inner: `<path d="M15.9356 264.456L171.498 108.893" stroke="currentColor" stroke-opacity="0.44" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/><path d="M-15.1731 77.7784L93.7209 186.672" stroke="currentColor" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/><path d="M-15.1759 186.676H93.7181V77.7816" stroke="currentColor" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  eher_richtig: {
    viewBox: "0 0 190 280",
    inner: `<path d="M17.9356 15.5294L173.498 171.092" stroke="currentColor" stroke-opacity="0.44" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/><path d="M-13.1731 202.207L95.7209 93.3129" stroke="currentColor" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/><path d="M-13.1759 93.3096H95.7181V202.204" stroke="currentColor" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  falsch: {
    viewBox: "0 0 181 186",
    inner: `<path d="M164.999 169.527L-55 169.527" stroke="currentColor" stroke-opacity="0.44" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/><path d="M54.9953 15.5293L54.9953 169.529" stroke="currentColor" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/><path d="M131.999 92.5293L54.9996 169.529L-22.0001 92.5293" stroke="currentColor" stroke-width="31.0587" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
};

// Fakten card preview: 4 mini cards in the verdict spectrum falsch → richtig
// (left → right). Pair the shortest myth per verdict with the real per-verdict
// card gradient + the (inlined) direction arrow.
const FAKTEN_SPECTRUM: CorrectnessClass[] = ["falsch", "eher_falsch", "eher_richtig", "richtig"];
const faktenCards = FAKTEN_SPECTRUM.map((v) => {
  const myth = previewMyths.find((m) => m.classification === v);
  if (!myth) return null;
  return { verdict: v, text: myth.text, gradient: getVerdictVisual(v).gradient, arrow: FAKTEN_ARROWS[v] };
}).filter(
  (x): x is {
    verdict: CorrectnessClass;
    text: string;
    gradient: string;
    arrow: { viewBox: string; inner: string };
  } => x !== null,
);

// Daten-Explorer card preview: a laconic Balken chart (matches the dashboard's
// BalkenBar — dotted axis + translucent verdict wash + value circle). Each bar
// animates from `idle` to `hover` on card hover. Values are placeholders.
const DATEN_BARS = [
  { accent: "#047857", idle: 42, hover: 57 }, // richtig (green)
  { accent: "#b45309", idle: 28, hover: 28 }, // eher_falsch (orange) — unchanged
  { accent: "#047857", idle: 31, hover: 14 }, // richtig (green)
  { accent: "#4d7c0f", idle: 49, hover: 64 }, // eher_richtig (olive)
];

// Per-topic icons lifted from the mobile tab bar (BaseLayout) — Lucide 24×24,
// drawn in currentColor so the badge can paint them white.
const ICONS: Record<string, string> = {
  quiz: `<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/>`,
  fakten: `<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>`,
  daten: `<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/>`,
  meine: `<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>`,
};

// The four quiz answer-buttons (verdict card + arrow) replicated pixel-for-pixel
// from the quiz play state (QuizCard ANSWER_OPTIONS) — no text labels. Order
// follows the Figma/screenshot: richtig · eher_falsch · eher_richtig · falsch.
const QUIZ_OPTIONS = [
  {
    value: "richtig",
    svg: `<svg width="30" height="22" viewBox="0 0 30 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M28.2041 1.39285L1.3916 1.39286" stroke="#A7D3C5" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/><path d="M14.7979 20.1604L14.7978 1.39168" stroke="#047857" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/><path d="M24.1826 10.7776L14.7982 1.39324L5.41386 10.7776" stroke="#047857" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    value: "eher_falsch",
    svg: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M32.2303 13.271L13.271 32.2303" stroke="#E0B58D" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.47932 9.47998L22.7508 22.7515" stroke="#B45309" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/><path d="M22.7508 9.47803V22.7495H9.47929" stroke="#B45309" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    value: "eher_richtig",
    svg: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M32.2303 20.351L13.271 1.39168" stroke="#C2D3A3" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.47932 24.142L22.7508 10.8705" stroke="#4D7C0F" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/><path d="M22.7508 24.144V10.8724H9.47929" stroke="#4D7C0F" stroke-width="2.78333" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    value: "falsch",
    svg: `<svg width="26" height="22" viewBox="0 0 26 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1.2666 18.8793C0.567207 18.8798 0 19.4464 0 20.1459C0 20.8454 0.567207 21.4121 1.2666 21.4125L24.2705 21.4125C24.9703 21.4125 25.5371 20.8457 25.5371 20.1459C25.5371 19.4462 24.9703 18.8793 24.2705 18.8793L1.2666 18.8793Z" fill="#E9A8B9"/><path d="M12.771 1.26703L12.771 19.3997" stroke="#BE123C" stroke-width="2.53404" stroke-linecap="round" stroke-linejoin="round"/><path d="M20.8223 10.3315L12.771 19.3978L4.71974 10.3315" stroke="#BE123C" stroke-width="2.53404" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];

// AI draft — pending ISD review. English glosses:
//   quiz   → "For young people & consumers"
//   fakten → "For parents & teachers"
//   daten  → "For professionals & teachers"
//   meine  → "For all target groups"
const CARD_AUDIENCE: Record<string, string> = {
  quiz:   "Für Jugendliche & Konsumierende",
  fakten: "Für Eltern & Lehrkräfte",
  daten:  "Für Fachkräfte & Lehrkräfte",
  meine:  "Für alle Zielgruppen",
};

const cards = [
  { mod: "quiz", icon: ICONS.quiz, ...quizTile },
  { mod: "fakten", icon: ICONS.fakten, ...faktenKartenTile },
  { mod: "daten", icon: ICONS.daten, ...datenExplorerTile },
  { mod: "meine", icon: ICONS.meine, ...meineInteressenTile },
];
---

<section class="four-paths" aria-labelledby="four-paths-quote" data-reveal>
  <div class="four-paths__inner">
    <div class="four-paths__card">
      <blockquote class="four-paths__quote" id="four-paths-quote">
        <span class="four-paths__quote-eyebrow">{hookQuote.eyebrow}</span>
        <span class="four-paths__quote-lead">{hookQuote.leadClause}</span>{" "}
        <span
          class="four-paths__quote-counter"
          data-classification={hookQuote.counterClassification}
        >
          {hookQuote.counterClause}
        </span>
      </blockquote>

      {cards.map((c) => (
        <a class={`path-card path-card--${c.mod}`} href={c.targetUrl}>
          <span class="path-card__go" aria-hidden="true">
            <span class="path-card__go-label">Anzeigen</span>
            <svg
              class="path-card__go-chevron"
              viewBox="0 0 24 24"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
            ><path d="m9 18 6-6-6-6"></path></svg>
          </span>
          <div class="path-card__top">
            <span class="path-card__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                width="17.5"
                height="17.5"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={c.icon}
              ></svg>
            </span>
            <span class="path-card__audience">{CARD_AUDIENCE[c.mod]}</span>
          </div>
          <h3 class="path-card__title">{c.title}</h3>
          <p class="path-card__body">{c.description}</p>

          {c.mod === "quiz" && (
            <div class="quiz-preview" aria-hidden="true">
              {QUIZ_OPTIONS.map((o) => (
                <span class={`quiz-preview__btn quiz-preview__btn--${o.value}`} set:html={o.svg}></span>
              ))}
            </div>
          )}

          {c.mod === "fakten" && (
            <div class="fakten-preview" aria-hidden="true">
              {faktenCards.map((fc) => (
                <span class={`fk-mini fk-mini--${fc.verdict}`} style={`background-image:${fc.gradient}`}>
                  <span class="fk-mini__statement">{fc.text}</span>
                  <svg
                    class="fk-mini__arrow"
                    viewBox={fc.arrow.viewBox}
                    fill="none"
                    preserveAspectRatio="xMidYMid meet"
                    set:html={fc.arrow.inner}
                  ></svg>
                </span>
              ))}
            </div>
          )}

          {c.mod === "daten" && (
            <div class="daten-preview" aria-hidden="true">
              <div class="daten-chart">
                <div class="daten-chart__axis">
                  <span class="daten-chart__tick" data-pos="0"></span>
                  <span class="daten-chart__tick" data-pos="25"></span>
                  <span class="daten-chart__tick" data-pos="50"></span>
                  <span class="daten-chart__tick" data-pos="75"></span>
                  <span class="daten-chart__tick" data-pos="100"></span>
                </div>
                {DATEN_BARS.map((b) => (
                  <div class="daten-bar" data-idle={b.idle} data-hover={b.hover}>
                    <span class="daten-bar__wash" style={`width:${b.idle}%;background:${b.accent}`}></span>
                    <span class="daten-bar__circle" style={`left:${b.idle}%;background:${b.accent}`}>{b.idle}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {c.mod === "meine" && (
            <div class="meine-preview" aria-hidden="true">
              {audienceChips.map((a) => {
                const Icon = AUDIENCE_ICONS_BY_FAQ_ID[a.id];
                return (
                  <span class="audience-dot">
                    {Icon && <Icon />}
                  </span>
                );
              })}
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  // Daten-Explorer card: tween the Balken bars from their idle to their hover
  // values (width + circle position + number) while the card is hovered.
  interface DBar {
    wash: HTMLElement | null;
    circle: HTMLElement | null;
    idle: number;
    hover: number;
    cur: number;
  }
  const dLerp = (a: number, b: number, t: number) => a + (b - a) * t;
  const dEase = (t: number) => 1 - Math.pow(1 - t, 3);
  document.querySelectorAll<HTMLElement>(".daten-preview").forEach((preview) => {
    const card = preview.closest<HTMLElement>(".path-card") ?? preview;
    const bars: DBar[] = Array.from(
      preview.querySelectorAll<HTMLElement>(".daten-bar"),
    ).map((bar) => ({
      wash: bar.querySelector<HTMLElement>(".daten-bar__wash"),
      circle: bar.querySelector<HTMLElement>(".daten-bar__circle"),
      idle: Number(bar.dataset.idle),
      hover: Number(bar.dataset.hover),
      cur: Number(bar.dataset.idle),
    }));
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let raf = 0;
    const apply = (b: DBar, v: number) => {
      if (b.wash) b.wash.style.width = v + "%";
      if (b.circle) {
        b.circle.style.left = v + "%";
        b.circle.textContent = String(Math.round(v));
      }
    };
    const tween = (toHover: boolean) => {
      cancelAnimationFrame(raf);
      const starts = bars.map((b) => b.cur);
      const targets = bars.map((b) => (toHover ? b.hover : b.idle));
      if (reduce) {
        bars.forEach((b, i) => { b.cur = targets[i]; apply(b, b.cur); });
        return;
      }
      const t0 = performance.now();
      const dur = 480;
      const step = (now: number) => {
        const e = dEase(Math.min((now - t0) / dur, 1));
        bars.forEach((b, i) => { b.cur = dLerp(starts[i], targets[i], e); apply(b, b.cur); });
        if (e < 1) raf = requestAnimationFrame(step);
      };
      raf = requestAnimationFrame(step);
    };
    card.addEventListener("mouseenter", () => tween(true));
    card.addEventListener("mouseleave", () => tween(false));
  });
</script>
