---
import { CORRECTNESS_COLORS, CORRECTNESS_BG_COLORS, CORRECTNESS_ICONS } from "@lib/dashboard/colors";
import type { CorrectnessClass } from "@lib/dashboard/types";
import "../../styles/home-headline.css";

export interface Props {
  eyebrow: string;
  leadClause: string;
  counterClause: string;
  counterClassification: CorrectnessClass;
  dashboardCardTitle: string;
  dashboardCardBody: string;
  dashboardCtaLabel: string;
  faktenKartenCardTitle: string;
  faktenKartenCardBody: string;
  faktenKartenCtaLabel: string;
  /** Real counts of myths per verdict, computed at build time in index.astro. */
  classificationCounts: Record<CorrectnessClass, number>;
  /** 3 real myth statements (one per representative verdict) for the deck preview. */
  previewCards: Array<{ cls: CorrectnessClass; label: string; text: string }>;
}

const {
  eyebrow,
  leadClause,
  counterClause,
  counterClassification,
  dashboardCardTitle,
  dashboardCardBody,
  dashboardCtaLabel,
  faktenKartenCardTitle,
  faktenKartenCardBody,
  faktenKartenCtaLabel,
  classificationCounts,
  previewCards,
} = Astro.props;

const counterColor = CORRECTNESS_COLORS[counterClassification];

// Sparkline order: keep canonical verdict order so colour reading is stable
// across the site (matches the legend in the Daten-Explorer).
const VERDICT_ORDER: Array<{ cls: CorrectnessClass; label: string }> = [
  { cls: "richtig",            label: "Richtig" },
  { cls: "eher_richtig",       label: "Eher richtig" },
  { cls: "eher_falsch",        label: "Eher falsch" },
  { cls: "falsch",             label: "Falsch" },
  { cls: "no_classification",  label: "Keine Aussage" },
];

const sparkBars = VERDICT_ORDER.map((v) => ({
  ...v,
  value: classificationCounts[v.cls] ?? 0,
}));
const totalMyths = sparkBars.reduce((sum, b) => sum + b.value, 0);
const maxBar = Math.max(1, ...sparkBars.map((b) => b.value));
---

<section class="headline-finding" aria-labelledby="headline-finding-heading">
  <div class="headline-finding__inner">
    <p class="headline-finding__eyebrow">{eyebrow}</p>

    <blockquote class="headline-finding__quote" id="headline-finding-heading">
      <span class="headline-finding__lead">{leadClause}</span>
      <span class="headline-finding__counter-row">
        <span class="headline-finding__counter-dot" style={`background:${counterColor}`} aria-hidden="true">
          <span class="headline-finding__counter-icon" style={`color:${counterColor}`}>
            {CORRECTNESS_ICONS[counterClassification]}
          </span>
        </span>
        <span class="headline-finding__counter">{counterClause}</span>
      </span>
    </blockquote>

    <div class="headline-finding__cards">
      <!-- Card A — Dashboard -->
      <a href="/daten-explorer/" class="headline-finding__card headline-finding__card--dashboard">
        <div class="headline-finding__card-preview">
          <div
            class="headline-finding__spark"
            role="img"
            aria-label={`Verteilung der ${totalMyths} Mythen nach Einordnung: ${sparkBars.map(b => `${b.label} ${b.value}`).join(', ')}`}
          >
            {sparkBars.map((b) => (
              <div class="headline-finding__spark-col">
                <span class="headline-finding__spark-count">{b.value}</span>
                <div
                  class="headline-finding__spark-bar"
                  style={`height:${(b.value / maxBar) * 100}%; background:${CORRECTNESS_COLORS[b.cls]}`}
                />
              </div>
            ))}
          </div>
          <div class="headline-finding__spark-legend" aria-hidden="true">
            {sparkBars.map((b) => (
              <span class="headline-finding__spark-legend-item">
                <span
                  class="headline-finding__spark-dot"
                  style={`background:${CORRECTNESS_COLORS[b.cls]}`}
                />
                <span class="headline-finding__spark-legend-label">{b.label}</span>
              </span>
            ))}
          </div>
        </div>
        <div class="headline-finding__card-body">
          <h3 class="headline-finding__card-title">{dashboardCardTitle}</h3>
          <p class="headline-finding__card-desc">{dashboardCardBody}</p>
          <p class="headline-finding__card-meta">{totalMyths} Mythen · 4 Zielgruppen</p>
          <span class="headline-finding__card-cta">
            {dashboardCtaLabel}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>

      <!-- Card B — Fakten-Karten -->
      <a href="/fakten-karten/" class="headline-finding__card headline-finding__card--fakten">
        <div class="headline-finding__card-preview">
          <div class="headline-finding__deck" aria-hidden="true">
            {previewCards.map((c, i) => (
              <div
                class={`headline-finding__deck-card headline-finding__deck-card--${i}`}
                style={`background:${CORRECTNESS_BG_COLORS[c.cls]}; border-color:${CORRECTNESS_COLORS[c.cls]}40;`}
              >
                <div class="headline-finding__deck-verdict" style={`background:${CORRECTNESS_COLORS[c.cls]}`}>
                  <span class="headline-finding__deck-icon">{CORRECTNESS_ICONS[c.cls]}</span>
                  <span class="headline-finding__deck-label">{c.label}</span>
                </div>
                <p class="headline-finding__deck-text">{c.text}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="headline-finding__card-body">
          <h3 class="headline-finding__card-title">{faktenKartenCardTitle}</h3>
          <p class="headline-finding__card-desc">{faktenKartenCardBody}</p>
          <p class="headline-finding__card-meta">{totalMyths} Karten · drehbar · teilbar</p>
          <span class="headline-finding__card-cta">
            {faktenKartenCtaLabel}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>
    </div>
  </div>
</section>
