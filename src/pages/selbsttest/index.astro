---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedEntries } from "@lib/content";
import "../../styles/quiz.css";

const entries = await getPublishedEntries("selbsttest");

// Filter out feedback-texte for the quiz index (it's not a playable quiz)
const quizzes = entries.filter(([slug]) => slug !== "feedback-texte");

// Quiz card data: emoji + question count
const quizMeta: Record<string, { emoji: string; count: number }> = {
  "quiz-alltag": { emoji: "\u2615", count: 10 },
  "quiz-gesellschaft": { emoji: "\uD83C\uDFDB\uFE0F", count: 9 },
  "quiz-koerper": { emoji: "\uD83E\uDEC0", count: 10 },
  "quiz-psyche": { emoji: "\uD83E\uDDE0", count: 11 },
};
---

<BaseLayout title="Selbsttest / Quiz" description="Testen Sie Ihr Wissen über Cannabis-Mythen">
  <h1>Selbsttest: Was wissen Sie über Cannabis?</h1>

  <div class="quiz-index__intro">
    <p>
      Testen Sie Ihr Wissen in vier thematischen Quiz-Modulen.
      Jedes Quiz enthält Fragen zu verbreiteten Cannabis-Mythen mit
      wissenschaftlich fundierten Erklärungen. Vergleichen Sie Ihre
      Einschätzungen mit denen der deutschen Bevölkerung.
    </p>
  </div>

  <section class="quiz-selection">
    {quizzes.map(([slug, entry]) => {
      const e = entry as any;
      const meta = quizMeta[slug as string];
      return (
        <a href={`/selbsttest/${slug}/`} class="quiz-select-card">
          <span class="quiz-select-card__emoji">{meta?.emoji || "\uD83D\uDCCB"}</span>
          <h2 class="quiz-select-card__title">{e.title}</h2>
          <span class="quiz-select-card__count">
            {meta?.count || e.questionCount || "?"} Fragen
          </span>
        </a>
      );
    })}
  </section>
</BaseLayout>
