---
import Markdoc from "@markdoc/markdoc";
import BaseLayout from "@layouts/BaseLayout.astro";
import { reader } from "@lib/content";

export async function getStaticPaths() {
  const slugs = await reader.collections.selbsttest.list();
  const paths = [];

  for (const slug of slugs) {
    const entry = await reader.collections.selbsttest.read(slug);
    if (entry && entry.status === "published") {
      paths.push({ params: { slug } });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const entry = await reader.collections.selbsttest.read(slug!);

if (!entry || entry.status !== "published") {
  return Astro.redirect("/selbsttest/");
}

const { content, internalNotes, ...meta } = entry;
const { node } = await content();
const html = Markdoc.renderers.html(Markdoc.transform(node));
---

<BaseLayout title={meta.title} description={meta.summary || undefined}>
  <article class="quiz-page">
    <header>
      <h1>{meta.title}</h1>
      {meta.theme && <p class="theme-label">Thema: {meta.theme}</p>}
      {(meta.questionCount ?? 0) > 0 && <p>{meta.questionCount} Fragen</p>}
    </header>

    <!--
      TODO: Replace this static content rendering with an interactive
      React quiz component (src/components/quiz/QuizPlayer.tsx).
      The current view shows the raw quiz content as a reference.
    -->
    <div class="quiz-content" set:html={html} />

    <footer>
      <a href="/selbsttest/">&larr; Alle Quiz-Module</a>
    </footer>
  </article>
</BaseLayout>
