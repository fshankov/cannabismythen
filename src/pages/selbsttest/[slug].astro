---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { reader } from "@lib/content";
import QuizPlayer from "@components/quiz/QuizPlayer";
import "../../styles/quiz.css";

export async function getStaticPaths() {
  const slugs = await reader.collections.selbsttest.list();
  const paths = [];

  for (const slug of slugs) {
    const entry = await reader.collections.selbsttest.read(slug);
    if (entry && entry.status === "published" && slug !== "feedback-texte") {
      paths.push({ params: { slug } });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const entry = await reader.collections.selbsttest.read(slug!);

if (!entry || entry.status !== "published") {
  return Astro.redirect("/selbsttest/");
}
---

<BaseLayout title={entry.title} description={entry.summary || "Cannabis-Quiz: Testen Sie Ihr Wissen"}>
  <article class="quiz-page">
    <QuizPlayer client:load quizSlug={slug!} />

    <footer>
      <a href="/selbsttest/">&larr; Alle Quiz-Module</a>
    </footer>
  </article>
</BaseLayout>
