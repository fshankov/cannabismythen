---
/**
 * Stage 5 of the Daten-Explorer refactor — `/zahlen-und-fakten/` was
 * renamed to `/daten-explorer/`. This stub preserves the query string
 * when redirecting (so `?view=streifen` etc. survive the rename) and
 * stays in place so external backlinks keep working.
 *
 * Defense in depth: edge middleware in `src/middleware.ts` short-
 * circuits before this fires for SSR; the prerendered static output
 * lives here for any path Netlify's static redirect rules miss.
 */
export const prerender = false;

const search = Astro.url.search;
return Astro.redirect(`/daten-explorer/${search}`, 301);
---
