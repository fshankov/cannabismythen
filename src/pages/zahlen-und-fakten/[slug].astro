---
/**
 * Stage 5 of the Daten-Explorer refactor — factsheet routes moved
 * to `/daten-explorer/{slug}/`. This stub preserves the query string
 * when redirecting and stays in place so external backlinks resolve.
 *
 * SSR-mode redirect (no `prerender = true`) so we can read the
 * incoming URL's query string and pass it through to the new path.
 * Edge middleware (`src/middleware.ts`) covers the same path; both
 * layers point the same way for defense in depth.
 */
export const prerender = false;

const { slug } = Astro.params;
const search = Astro.url.search;
return Astro.redirect(`/daten-explorer/${slug}/${search}`, 301);
---
