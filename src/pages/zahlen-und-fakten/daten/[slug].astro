---
/**
 * Stage 5 of the Daten-Explorer refactor — these legacy "daten/"
 * dashboard pages now redirect into the Daten-Explorer entry while
 * preserving any query string. SSR-mode (no `prerender = true`) so
 * we can read the incoming URL.
 */
export const prerender = false;

const search = Astro.url.search;
return Astro.redirect(`/daten-explorer/${search}`, 301);
---
