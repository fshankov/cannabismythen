---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { reader } from "@lib/content";
import { HeroBlock } from "@components/hero/HeroBlock";
import { mythPositions } from "@components/hero/mythPositions";
import type { HeroMyth } from "@components/hero/HeroBlock";

// ── Hero content from Keystatic ─────────────────────────────────────────────
const heroBlockData = await reader.singletons.heroBlock.read();
const headline1 = heroBlockData?.headline1 ?? "Was glauben wir zu wissen —";
const headline2 = heroBlockData?.headline2 ?? "und was stimmt wirklich?";
const eyebrow   = heroBlockData?.eyebrow   ?? "ISD Hamburg · Bevölkerungsbefragung in Deutschland · Wissenschaftlich geprüft";

// ── Myth classifications from Keystatic ────────────────────────────────────
const clsBySlugPrefix = new Map<string, string>();
const allSlugs = await reader.collections.zahlenUndFakten.list();

for (const slug of allSlugs) {
  const entry = await reader.collections.zahlenUndFakten.read(slug);
  if (!entry) continue;
  const prefixMatch = slug.match(/^(m\d+-m\d+|m\d+)/);
  if (prefixMatch) {
    clsBySlugPrefix.set(prefixMatch[1], entry.classification);
  }
}

const heroMyths: HeroMyth[] = mythPositions.map(pos => ({
  id: pos.id,
  text: pos.text,
  classification: clsBySlugPrefix.get(pos.id) ?? "keine_aussage",
  position: pos,
}));
---

<BaseLayout title="Startseite" heroMode={true}>
  <HeroBlock
    myths={heroMyths}
    headline1={headline1}
    headline2={headline2}
    eyebrow={eyebrow}
    client:load
  />
</BaseLayout>
