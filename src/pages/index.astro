---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import "../styles/home-reveal.css";
import { reader, getPublishedEntries } from "@lib/content";
import HeroBlock from "@components/home/HeroBlock";
import type { HeroMyth } from "@components/home/HeroBlock";
import NumbersStripBlock from "@components/home/NumbersStripBlock.astro";
import FourPathsBlock from "@components/home/FourPathsBlock.astro";
import type { PreviewMyth } from "@components/home/previews/FaktenKartenPreviewTile.astro";
import type { AudienceChip } from "@components/home/previews/MeineInteressenPreviewTile.astro";
import { getAllAudiences } from "@lib/faq";

// ── Interactive hero (Pendel-Lupe-Ring) ────────────────────────────────────
// All 42 myth statements ride a raised oval ring around the central question
// and reveal one at a time in the spotlight (or on hover). `heroMyths` is built
// below from the published myth content (accurate titles, stripped of the
// "Mythos N:" prefix) — see the mythRecords loop. Design spec:
// docs/superpowers/specs/2026-05-31-homepage-hero-pendulum-design.md
// H1 — two lines, SEO-friendly (keyword "Cannabis" present). ISD-provided wording (Backlog 1.1, 2026-06-03).
const heroHeadline1 = "Was glauben wir über Cannabis zu wissen —";
const heroHeadline2 = "und was stimmt wirklich?";
const heroEyebrow   = "ISD Hamburg · Bevölkerungsbefragung zu Cannabis in Deutschland · Wissenschaftlich geprüft";

// ── Fakten-Karten preview: pick three short representative myths ───────────
type MythRecord = {
  prefix: string;
  classification: string;
  title: string;
  categoryGroup: string;
  summary: string;
};
const mythRecords: MythRecord[] = [];

for (const [slug, entry] of await getPublishedEntries("zahlenUndFakten")) {
  const prefixMatch = slug.match(/^m\d+/);
  if (!prefixMatch) continue;
  const e = entry as { classification: string; title?: string; cardShortSummary?: string; categoryGroup?: string };
  // Strip the "Mythos N: " prefix and trailing period so the title alone
  // fits the small preview-card stripes.
  const title = (e.title ?? "")
    .replace(/^Mythos\s+\d+(?:\/\d+)?\s*:\s*/i, "")
    .replace(/\s*\([a-z]\)/gi, "")
    .replace(/[.\s]+$/, "")
    .trim();
  mythRecords.push({
    prefix: prefixMatch[0],
    classification: e.classification,
    title,
    categoryGroup: e.categoryGroup ?? "",
    summary: e.cardShortSummary ?? "",
  });
}

// All 42 hero myths in m01→m42 order. The hero floats a verdict GLYPH per myth;
// `text` is the FULL statement (stripped .mdoc title) shown as the caption that
// fades in on hover / auto-spotlight.
const heroMyths: HeroMyth[] = [...mythRecords]
  .sort((a, b) => a.prefix.localeCompare(b.prefix))
  .map((r) => ({ text: r.title, classification: r.classification }));

function pickShortest(cls: string): MythRecord | undefined {
  return mythRecords
    .filter((r) => r.classification === cls)
    .sort((a, b) => a.title.length - b.title.length)[0];
}

// One representative myth per verdict → the Fakten-Karten tile cycles the real
// card front (gradient + arrow + statement + category) across all verdicts.
const previewMyths: PreviewMyth[] = [
  pickShortest("richtig"),
  pickShortest("eher_richtig"),
  pickShortest("eher_falsch"),
  pickShortest("falsch"),
  pickShortest("keine_aussage"),
]
  .filter((r): r is MythRecord => r !== undefined)
  .map((r) => ({ text: r.title, classification: r.classification, categoryGroup: r.categoryGroup, summary: r.summary }));

// ── Editorial section content ──────────────────────────────────────────────
const numbersStripData = await reader.singletons.numbersStrip.read();
const headlineFinding = await reader.singletons.headlineFinding.read();
const fourPathsData = await reader.singletons.fourPaths.read();
// The five FAQ audiences, as colour-coded rows for the Meine-Interessen tile.
const audienceMetaList = await getAllAudiences();
const audienceChips: AudienceChip[] = audienceMetaList.map((a) => ({
  id: a.id,
  label: a.cardLabel,
}));
---

<BaseLayout title="Startseite" heroMode={true}>
  <HeroBlock
    myths={heroMyths}
    headline1={heroHeadline1}
    headline2={heroHeadline2}
    eyebrow={heroEyebrow}
    client:load
  />

  <div class="home-canvas">
  {headlineFinding && fourPathsData && (
    <FourPathsBlock
      hookQuote={{
        eyebrow: headlineFinding.eyebrow,
        leadClause: headlineFinding.leadClause,
        counterClause: headlineFinding.counterClause,
        counterClassification: headlineFinding.counterClassification,
      }}
      quizTile={fourPathsData.quizTile}
      faktenKartenTile={fourPathsData.faktenKartenTile}
      datenExplorerTile={fourPathsData.datenExplorerTile}
      meineInteressenTile={fourPathsData.meineInteressenTile}
      previewMyths={previewMyths}
      audienceChips={audienceChips}
    />
  )}

  {numbersStripData && (
    <NumbersStripBlock
      eyebrow={numbersStripData.eyebrow}
      numerals={numbersStripData.numerals}
    />
  )}

  </div>
</BaseLayout>

<style>
  /* Home canvas — the warm off-white field blocks sit on. The dark hero
     above and the footer below own their own backgrounds. Full-bleed inside
     the hero page's edge-to-edge <main>; each block's __inner owns the
     homepage-local ~1200px container width via --home-container.
     padding-bottom provides clearance before the footer for the teaser
     block (open canvas text, no card) which is now the last block. */
  .home-canvas {
    --home-container: 1200px;
    background: #faf9f5;
    padding-top: 48px;
    padding-bottom: 16px;
  }


</style>
