---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { reader } from "@lib/content";
import ScrollytellingViewer from "@components/scrollytelling/ScrollytellingViewer";

// Load the v2 scrollytelling entry (the only published narrative)
const allSlugs = await reader.collections.startseite.list();
let scrollySteps: any[] = [];
let scrollyTitle = "";

for (const slug of allSlugs) {
  if (slug === "chart-specifications") continue;
  const entry = await reader.collections.startseite.read(slug);
  if (entry && entry.status === "published" && entry.steps && entry.steps.length > 0) {
    scrollyTitle = entry.title;
    scrollySteps = entry.steps.map((s: any) => ({
      stepNumber: s.stepNumber,
      heading: s.heading,
      bodyText: s.bodyText,
      hint: s.hint || "",
      vizType: s.vizType,
      ctaLabel: s.ctaLabel || "",
      ctaUrl: s.ctaUrl || "",
    }));
    break; // use the first published entry with steps
  }
}
---

<BaseLayout title="Startseite">
  <h1>Cannabis: Mythen &amp; Evidenz</h1>
  <p>
    Willkommen bei der evidenzbasierten Informationsplattform zu Cannabis-Mythen.
    Dieses Projekt basiert auf dem CaRM-Forschungsprojekt und bietet wissenschaftlich
    fundierte Einordnungen zu 42 verbreiteten Cannabis-Mythen.
  </p>

  {scrollySteps.length > 0 ? (
    <ScrollytellingViewer
      steps={scrollySteps}
      title={scrollyTitle}
      client:visible
    />
  ) : (
    <p><em>Das Scrollytelling wird in Kürze hier angezeigt.</em></p>
  )}

  <section>
    <h2>Inhalte</h2>
    <ul>
      <li><a href="/zahlen-und-fakten/">Zahlen &amp; Fakten</a> — Wissenschaftliche Einordnung aller 42 Mythen und Daten nach Zielgruppen</li>
      <li><a href="/haeufige-fragen/">Häufige Fragen</a> — Häufig gestellte Fragen nach Themen</li>
      <li><a href="/selbsttest/">Selbsttest / Quiz</a> — Testen Sie Ihr Wissen</li>
      <li><a href="/ueber-uns/">Über uns</a> — Team, Methodik, Hintergrund</li>
    </ul>
  </section>
</BaseLayout>
