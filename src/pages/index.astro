---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { reader, getPublishedEntries } from "@lib/content";
import { deriveHeroLabel } from "@lib/myth";
import { HeroBlock } from "@components/hero/HeroBlock";
import { mythPositions } from "@components/hero/mythPositions";
import type { HeroMyth } from "@components/hero/HeroBlock";
import NumbersStripBlock from "@components/home/NumbersStripBlock.astro";
import FourPathsBlock from "@components/home/FourPathsBlock.astro";
import AudienceShortcutBlock from "@components/home/AudienceShortcutBlock.astro";
import type { AudienceCard } from "@components/home/AudienceShortcutBlock.astro";
import type { PreviewMyth } from "@components/home/previews/FaktenKartenPreviewTile.astro";
import type { AudienceChip } from "@components/home/previews/MeineInteressenPreviewTile.astro";
import { getAllAudiences } from "@lib/faq";

// ── Hero content from Keystatic (legacy schema — replaced in step 5) ────────
const heroBlockData = await reader.singletons.heroBlock.read();
const headline1 = heroBlockData?.headline1 ?? "Was glauben wir zu wissen —";
const headline2 = heroBlockData?.headline2 ?? "und was stimmt wirklich?";
const heroEyebrow = heroBlockData?.eyebrow ??
  "ISD Hamburg · Bevölkerungsbefragung in Deutschland · Wissenschaftlich geprüft";

// ── Read all myth entries once — fuel the hero + the Fakten-Karten preview ──
type MythRecord = {
  prefix: string;
  classification: string;
  heroLabel: string;
};

const mythRecords: MythRecord[] = [];

for (const [slug, entry] of await getPublishedEntries("zahlenUndFakten")) {
  const prefixMatch = slug.match(/^m\d+/);
  if (!prefixMatch) continue;
  const e = entry as { classification: string; title?: string };
  mythRecords.push({
    prefix: prefixMatch[0],
    classification: e.classification,
    heroLabel: deriveHeroLabel(e.title ?? ""),
  });
}

const recordByPrefix = new Map(mythRecords.map((r) => [r.prefix, r]));

const heroMyths: HeroMyth[] = mythPositions.map((pos) => {
  const rec = recordByPrefix.get(pos.id);
  return {
    id: pos.id,
    text: rec?.heroLabel || pos.text,
    classification: rec?.classification ?? "keine_aussage",
    position: pos,
  };
});

// ── Fakten-Karten preview: pick three short representative myths ───────────
function pickShortest(cls: string): MythRecord | undefined {
  return mythRecords
    .filter((r) => r.classification === cls)
    .sort((a, b) => a.heroLabel.length - b.heroLabel.length)[0];
}

const previewMyths: PreviewMyth[] = [
  pickShortest("richtig"),
  pickShortest("eher_falsch"),
  pickShortest("falsch"),
]
  .filter((r): r is MythRecord => r !== undefined)
  .map((r) => ({ text: r.heroLabel, classification: r.classification }));

// ── Editorial section content ──────────────────────────────────────────────
const numbersStripData = await reader.singletons.numbersStrip.read();
const headlineFinding = await reader.singletons.headlineFinding.read();
const fourPathsData = await reader.singletons.fourPaths.read();
const audienceShortcutData = await reader.singletons.audienceShortcut.read();

// Audience metadata for the audience-shortcut block AND the Meine-Interessen tile.
const audienceMetaList = await getAllAudiences();
const audienceMetaById = new Map(audienceMetaList.map((a) => [a.id, a]));

const audienceCards: AudienceCard[] = (audienceShortcutData?.cards ?? [])
  .flatMap((card): AudienceCard[] => {
    const meta = audienceMetaById.get(card.audienceId as never);
    if (!meta) return [];
    return [
      {
        audienceId: card.audienceId,
        recommendation: card.recommendation,
        targetUrl: card.targetUrl,
        cardLabel: meta.cardLabel,
        emoji: meta.emoji,
        accentColor: meta.accentColor,
      },
    ];
  });

const audienceChips: AudienceChip[] = audienceMetaList.map((a) => ({
  emoji: a.emoji,
  cardLabel: a.cardLabel,
  accentColor: a.accentColor,
}));
---

<BaseLayout title="Startseite" heroMode={true}>
  <HeroBlock
    myths={heroMyths}
    headline1={headline1}
    headline2={headline2}
    eyebrow={heroEyebrow}
    client:load
  />

  {numbersStripData && (
    <NumbersStripBlock
      eyebrow={numbersStripData.eyebrow}
      numerals={numbersStripData.numerals}
      subline={numbersStripData.subline}
      linkLabel={numbersStripData.linkLabel}
      linkUrl={numbersStripData.linkUrl}
    />
  )}

  {headlineFinding && fourPathsData && (
    <FourPathsBlock
      hookQuote={{
        eyebrow: headlineFinding.eyebrow,
        leadClause: headlineFinding.leadClause,
        counterClause: headlineFinding.counterClause,
        counterClassification: headlineFinding.counterClassification,
      }}
      quizTile={fourPathsData.quizTile}
      faktenKartenTile={fourPathsData.faktenKartenTile}
      datenExplorerTile={fourPathsData.datenExplorerTile}
      meineInteressenTile={fourPathsData.meineInteressenTile}
      previewMyths={previewMyths}
      audienceChips={audienceChips}
    />
  )}

  {audienceShortcutData && audienceCards.length > 0 && (
    <AudienceShortcutBlock
      eyebrow={audienceShortcutData.eyebrow}
      headline={audienceShortcutData.headline}
      lede={audienceShortcutData.lede}
      cards={audienceCards}
    />
  )}
</BaseLayout>
