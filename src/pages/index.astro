---
export const prerender = true;

import "../styles/home-hero-frage.css";
import BaseLayout from "@layouts/BaseLayout.astro";
import { reader, getPublishedEntries } from "@lib/content";
import HeroFrageBlock from "@components/home/HeroFrageBlock";
import type { HeroPair } from "@components/home/HeroFrageBlock";
import type { CorrectnessClass } from "@lib/dashboard/types";
import NumbersStripBlock from "@components/home/NumbersStripBlock.astro";
import FourPathsBlock from "@components/home/FourPathsBlock.astro";
import AudienceShortcutBlock from "@components/home/AudienceShortcutBlock.astro";
import type { AudienceCard } from "@components/home/AudienceShortcutBlock.astro";
import ProjectStripBlock from "@components/home/ProjectStripBlock.astro";
import type { PreviewMyth } from "@components/home/previews/FaktenKartenPreviewTile.astro";
import type { AudienceChip } from "@components/home/previews/MeineInteressenPreviewTile.astro";
import { getAllAudiences } from "@lib/faq";
import { AUDIENCE_COLOR_VAR_BY_FAQ_ID } from "@lib/icons/lookups";
import type { FaqAudienceId } from "@lib/icons/lookups";

/* The icon-registry refactor (commit 4e08023) removed `emoji` and
 * `accentColor` from the FAQ audience meta — those now live as Lucide
 * icon components and CSS custom properties. The Round-1 home page
 * still wants string-shaped values for emoji + color so it can pass
 * them through Astro/JSX props without forwarding React components.
 *
 * Map per-audience-id to fallback strings here. When the home page
 * gets the icon-swap pass too, this map disappears in favour of
 * <Icon /> components and `var(--audience-{id})` references. */
const AUDIENCE_EMOJI_BY_ID: Record<FaqAudienceId, string> = {
  eltern: "👨‍👩‍👧",
  jugendliche: "🧒",
  konsumierende: "🌿",
  lehrkraefte: "🏫",
  fachkraefte: "🩺",
};

function audienceAccentColor(id: string): string {
  const v = AUDIENCE_COLOR_VAR_BY_FAQ_ID[id as FaqAudienceId];
  return v ? `var(${v})` : "var(--color-accent)";
}
function audienceEmoji(id: string): string {
  return AUDIENCE_EMOJI_BY_ID[id as FaqAudienceId] ?? "•";
}

// ── Hero content from Keystatic ─────────────────────────────────────────────
const heroBlockData = await reader.singletons.heroBlock.read();

// The Keystatic schema uses `keine_aussage` for the no-classification option;
// the rest of the site uses the canonical `no_classification` key. Translate
// once at the boundary so HeroFrageBlock can speak the same type everywhere.
const YAML_TO_CORRECTNESS: Record<string, CorrectnessClass> = {
  richtig: "richtig",
  eher_richtig: "eher_richtig",
  eher_falsch: "eher_falsch",
  falsch: "falsch",
  keine_aussage: "no_classification",
};

const heroPairs: HeroPair[] = (heroBlockData?.pairs ?? []).map((p) => ({
  belief: p.belief,
  science: p.science,
  mythSlug: p.mythSlug,
  verdict: YAML_TO_CORRECTNESS[p.verdict] ?? "no_classification",
}));

const heroBackgroundQuestions: string[] = [...(heroBlockData?.backgroundQuestions ?? [])];

// ── Fakten-Karten preview: pick three short representative myths ───────────
type MythRecord = { prefix: string; classification: string; title: string };
const mythRecords: MythRecord[] = [];

for (const [slug, entry] of await getPublishedEntries("zahlenUndFakten")) {
  const prefixMatch = slug.match(/^m\d+/);
  if (!prefixMatch) continue;
  const e = entry as { classification: string; title?: string };
  // Strip the "Mythos N: " prefix and trailing period so the title alone
  // fits the small preview-card stripes.
  const title = (e.title ?? "")
    .replace(/^Mythos\s+\d+(?:\/\d+)?\s*:\s*/i, "")
    .replace(/\s*\([a-z]\)/gi, "")
    .replace(/[.\s]+$/, "")
    .trim();
  mythRecords.push({ prefix: prefixMatch[0], classification: e.classification, title });
}

function pickShortest(cls: string): MythRecord | undefined {
  return mythRecords
    .filter((r) => r.classification === cls)
    .sort((a, b) => a.title.length - b.title.length)[0];
}

const previewMyths: PreviewMyth[] = [
  pickShortest("richtig"),
  pickShortest("eher_falsch"),
  pickShortest("falsch"),
]
  .filter((r): r is MythRecord => r !== undefined)
  .map((r) => ({ text: r.title, classification: r.classification }));

// ── Editorial section content ──────────────────────────────────────────────
const numbersStripData = await reader.singletons.numbersStrip.read();
const headlineFinding = await reader.singletons.headlineFinding.read();
const fourPathsData = await reader.singletons.fourPaths.read();
const audienceShortcutData = await reader.singletons.audienceShortcut.read();
const projectStripData = await reader.singletons.projectStrip.read();

// Audience metadata for the audience-shortcut block AND the Meine-Interessen tile.
const audienceMetaList = await getAllAudiences();
const audienceMetaById = new Map(audienceMetaList.map((a) => [a.id, a]));

const audienceCards: AudienceCard[] = (audienceShortcutData?.cards ?? [])
  .flatMap((card): AudienceCard[] => {
    const meta = audienceMetaById.get(card.audienceId as never);
    if (!meta) return [];
    return [
      {
        audienceId: card.audienceId,
        recommendation: card.recommendation,
        targetUrl: card.targetUrl,
        cardLabel: meta.cardLabel,
        emoji: audienceEmoji(card.audienceId),
        accentColor: audienceAccentColor(card.audienceId),
      },
    ];
  });

/* The Meine-Interessen tile rotates one card at a time and shows the
 * audience-shortcut recommendation underneath the name, so we join the
 * audience meta with the recommendation from the shortcut YAML. If a
 * meta entry isn't covered by a card, we fall back to the empty string
 * — the tile then shows just emoji + label for that audience. */
const recommendationByAudienceId = new Map(
  (audienceShortcutData?.cards ?? []).map((c) => [c.audienceId, c.recommendation]),
);
const audienceChips: AudienceChip[] = audienceMetaList.map((a) => ({
  emoji: audienceEmoji(a.id),
  cardLabel: a.cardLabel,
  accentColor: audienceAccentColor(a.id),
  recommendation: recommendationByAudienceId.get(a.id as never) ?? "",
}));
---

<BaseLayout title="Startseite" heroMode={true}>
  {heroBlockData && heroPairs.length > 0 && (
    <HeroFrageBlock
      eyebrow={heroBlockData.eyebrow}
      beliefLabel={heroBlockData.beliefLabel}
      scienceLabel={heroBlockData.scienceLabel}
      backgroundQuestions={heroBackgroundQuestions}
      pairs={heroPairs}
      rotationSeconds={heroBlockData.rotationSeconds ?? 6}
      primaryCtaLabel={heroBlockData.primaryCtaLabel}
      primaryCtaUrl={heroBlockData.primaryCtaUrl}
      secondaryCtaLabel={heroBlockData.secondaryCtaLabel}
      secondaryCtaUrl={heroBlockData.secondaryCtaUrl}
      client:load
    />
  )}

  {numbersStripData && (
    <NumbersStripBlock
      eyebrow={numbersStripData.eyebrow}
      numerals={numbersStripData.numerals}
      subline={numbersStripData.subline}
      linkLabel={numbersStripData.linkLabel}
      linkUrl={numbersStripData.linkUrl}
    />
  )}

  {headlineFinding && fourPathsData && (
    <FourPathsBlock
      hookQuote={{
        eyebrow: headlineFinding.eyebrow,
        leadClause: headlineFinding.leadClause,
        counterClause: headlineFinding.counterClause,
        counterClassification: headlineFinding.counterClassification,
      }}
      quizTile={fourPathsData.quizTile}
      faktenKartenTile={fourPathsData.faktenKartenTile}
      datenExplorerTile={fourPathsData.datenExplorerTile}
      meineInteressenTile={fourPathsData.meineInteressenTile}
      previewMyths={previewMyths}
      audienceChips={audienceChips}
    />
  )}

  {audienceShortcutData && audienceCards.length > 0 && (
    <AudienceShortcutBlock
      eyebrow={audienceShortcutData.eyebrow}
      headline={audienceShortcutData.headline}
      lede={audienceShortcutData.lede}
      cards={audienceCards}
    />
  )}

  {projectStripData && (
    <ProjectStripBlock credit={projectStripData.credit} links={projectStripData.links} />
  )}
</BaseLayout>
