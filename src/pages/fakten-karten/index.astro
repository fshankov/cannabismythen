---
export const prerender = true;

import Markdoc from "@markdoc/markdoc";
import BaseLayout from "@layouts/BaseLayout.astro";
import FaktenKartenExplorer from "@components/fakten-karten/FaktenKartenExplorer";
import { reader, getPublishedEntries } from "@lib/content";
import "../../styles/quiz.css";

// Combined myth factsheets: one .mdoc covers two CaRM myth IDs.
// Map the secondary myth ID to the same slug and content.
const COMBINED_MYTHS: Record<number, number> = {
  32: 31, // m31-m32-entspannt-aggressiv
  37: 36, // m36-m37-leistungen-niveau
  42: 41, // m41-m42-anstieg-konsum
};

// Build myth ID → factsheet slug mapping
const factsheetEntries = await getPublishedEntries("zahlenUndFakten");

// Pre-render factsheet HTML for the detail panel (same approach as zahlen-und-fakten)
const mythContentMap: Record<
  number,
  {
    html: string;
    title: string;
    classification: string;
    classificationLabel: string;
    refCount: number;
  }
> = {};

// Build the myths array for card display
const myths: {
  mythNumber: number;
  title: string;
  classification: string;
  classificationLabel: string;
  cardSummary: string;
  categoryGroup: string;
  slug: string;
}[] = [];

for (const [slug, entry] of factsheetEntries) {
  const e = entry as any;
  if (!e.mythNumber) continue;

  // Strip "Mythos XX:" or "Mythos XX/YY:" prefix from the display title
  const rawTitle = e.title as string;
  const cleanTitle = rawTitle.replace(/^Mythos\s+\d+(?:\/\d+)?:\s*/i, "");

  // Build myth entry for the card
  myths.push({
    mythNumber: e.mythNumber,
    title: cleanTitle,
    classification: e.classification || "",
    classificationLabel: e.classificationLabel || "",
    cardSummary: e.cardSummary || "",
    categoryGroup: e.categoryGroup || "",
    slug,
  });

  try {
    const fullEntry = await reader.collections.zahlenUndFakten.read(slug);
    if (fullEntry && fullEntry.content) {
      const { node } = await fullEntry.content();
      const fullHtml = Markdoc.renderers.html(Markdoc.transform(node));

      const refMatch = fullHtml.match(/<li>/g);
      const refCount = refMatch ? refMatch.length : 0;

      mythContentMap[e.mythNumber] = {
        html: fullHtml,
        title: cleanTitle,
        classification: (fullEntry as any).classification || "",
        classificationLabel: (fullEntry as any).classificationLabel || "",
        refCount,
      };
    }
  } catch {
    // If a factsheet fails to render, skip it
  }
}

// Copy content entries for secondary combined myth IDs
for (const [secondary, primary] of Object.entries(COMBINED_MYTHS)) {
  const p = Number(primary);
  if (mythContentMap[p]) {
    mythContentMap[Number(secondary)] = mythContentMap[p];
  }
}

// Sort myths by mythNumber ascending
myths.sort((a, b) => a.mythNumber - b.mythNumber);
---

<BaseLayout title="Fakten-Karten" description="42 Cannabis-Mythen — sofort erkennbar wahr oder falsch, mit wissenschaftlicher Einordnung.">
  <h1>Fakten-Karten</h1>
  <p>Stimmt das? 42 verbreitete Cannabis-Mythen, sofort eingeordnet — tippen Sie auf eine Karte für die Erklärung.</p>
  <FaktenKartenExplorer
    client:load
    myths={JSON.stringify(myths)}
    mythContent={JSON.stringify(mythContentMap)}
  />
</BaseLayout>
