---
export const prerender = true;

import Markdoc from "@markdoc/markdoc";
import BaseLayout from "@layouts/BaseLayout.astro";
import FaktenKartenExplorer from "@components/fakten-karten/FaktenKartenExplorer";
import { reader, getPublishedEntries } from "@lib/content";
import type { MythGroupMetrics } from "@lib/dashboard/types";
// Direct JSON import — Vite bundles the 79 KB into the prerender chunk at
// build time. The public copy at /data/carm-data.json stays put for the
// Daten-Explorer's runtime `fetch()`. Previously this used
// `readFile(new URL("../../../public/data/carm-data.json", import.meta.url))`
// which broke under Netlify's prerender step: after Vite bundling,
// `import.meta.url` points at .netlify/build/.prerender/chunks/index_*.mjs,
// so the relative walk-up resolved to a non-existent path.
import carmRawJson from "../../../public/data/carm-data.json";
import "../../styles/quiz.css";

// Combined myth factsheets: one .mdoc covers two CaRM myth IDs.
// Map the secondary myth ID to the same slug and content.
const COMBINED_MYTHS: Record<number, number> = {
  32: 31, // m31-m32-entspannt-aggressiv
  37: 36, // m36-m37-leistungen-niveau
  42: 41, // m41-m42-anstieg-konsum
};

// ── Build-time per-myth metric slice ────────────────────────────
// Reads `public/data/carm-data.json` once at build, slices by myth_id,
// and forwards a typed `MythGroupMetrics` per myth to the React island.
// The exact same dataset powers the Daten-Explorer at runtime; doing
// the slice at build time avoids a redundant fetch on the lighter
// fakten-karten page (it doesn't otherwise touch the dashboard data).
//
// `general_population` is excluded — it mixes minors and adults and is
// not displayed on any user-facing chart (mirrors EXCLUDED_GROUP_IDS
// in src/lib/dashboard/data.ts).
const VALID_GROUPS: ReadonlySet<string> = new Set([
  "adults",
  "minors",
  "consumers",
  "young_adults",
  "parents",
]);

interface RawMetric {
  myth_id: number;
  group_id: string;
  awareness: number | null;
  significance: number | null;
  correctness: number | null;
  prevention_significance: number | null;
  population_relevance: number | null;
}

const carmRaw = carmRawJson as { metrics: RawMetric[] };

const groupMetricsByMyth: Record<number, MythGroupMetrics> = {};
for (const m of carmRaw.metrics) {
  if (!VALID_GROUPS.has(m.group_id)) continue;
  if (!groupMetricsByMyth[m.myth_id]) groupMetricsByMyth[m.myth_id] = [];
  groupMetricsByMyth[m.myth_id].push({
    group_id: m.group_id as MythGroupMetrics[number]["group_id"],
    awareness: m.awareness,
    significance: m.significance,
    correctness: m.correctness,
    prevention_significance: m.prevention_significance,
    population_relevance: m.population_relevance,
  });
}

// Build myth ID → factsheet slug mapping
const factsheetEntries = await getPublishedEntries("zahlenUndFakten");

// Pre-render factsheet HTML for the detail panel (same approach as zahlen-und-fakten)
const mythContentMap: Record<
  number,
  {
    html: string;
    title: string;
    classification: string;
    classificationLabel: string;
    refCount: number;
  }
> = {};

// Build the myths array for card display
const myths: {
  mythNumber: number;
  title: string;
  classification: string;
  classificationLabel: string;
  cardSummary: string;
  categoryGroup: string;
  slug: string;
}[] = [];

for (const [slug, entry] of factsheetEntries) {
  const e = entry as any;
  if (!e.mythNumber) continue;

  // Strip "Mythos XX:" or "Mythos XX/YY:" prefix from the display title
  const rawTitle = e.title as string;
  const cleanTitle = rawTitle.replace(/^Mythos\s+\d+(?:\/\d+)?:\s*/i, "");

  // Build myth entry for the card
  myths.push({
    mythNumber: e.mythNumber,
    title: cleanTitle,
    classification: e.classification || "",
    classificationLabel: e.classificationLabel || "",
    cardSummary: e.cardSummary || "",
    categoryGroup: e.categoryGroup || "",
    slug,
  });

  try {
    const fullEntry = await reader.collections.zahlenUndFakten.read(slug);
    if (fullEntry && fullEntry.content) {
      const { node } = await fullEntry.content();
      const fullHtml = Markdoc.renderers.html(Markdoc.transform(node));

      const refMatch = fullHtml.match(/<li>/g);
      const refCount = refMatch ? refMatch.length : 0;

      mythContentMap[e.mythNumber] = {
        html: fullHtml,
        title: cleanTitle,
        classification: (fullEntry as any).classification || "",
        classificationLabel: (fullEntry as any).classificationLabel || "",
        refCount,
      };
    }
  } catch {
    // If a factsheet fails to render, skip it
  }
}

// Copy content entries for secondary combined myth IDs
for (const [secondary, primary] of Object.entries(COMBINED_MYTHS)) {
  const p = Number(primary);
  if (mythContentMap[p]) {
    mythContentMap[Number(secondary)] = mythContentMap[p];
  }
  // The CaRM dataset has its own metric record per CaRM myth_id —
  // i.e. m32 has its own row independent of m31. Only fall back to
  // the primary's metrics if the dataset doesn't carry the secondary
  // (defensive — should never trigger today but means future
  // editorial-only combined myths still get a chart).
  const s = Number(secondary);
  if (!groupMetricsByMyth[s] && groupMetricsByMyth[p]) {
    groupMetricsByMyth[s] = groupMetricsByMyth[p];
  }
}

// Sort myths by mythNumber ascending
myths.sort((a, b) => a.mythNumber - b.mythNumber);
---

<BaseLayout title="Fakten-Karten" description="42 Cannabis-Mythen — sofort erkennbar wahr oder falsch, mit wissenschaftlicher Einordnung.">
  <h1>Fakten-Karten</h1>
  <p>Stimmt das? 42 verbreitete Cannabis-Mythen, sofort eingeordnet — tippen Sie auf eine Karte für die Erklärung.</p>
  <FaktenKartenExplorer
    client:load
    myths={JSON.stringify(myths)}
    mythContent={JSON.stringify(mythContentMap)}
    groupMetrics={JSON.stringify(groupMetricsByMyth)}
  />
</BaseLayout>
