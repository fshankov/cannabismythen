---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import FaktenKartenExplorer from "@components/fakten-karten/FaktenKartenExplorer";
import { getPublishedEntries } from "@lib/content";
import { buildGroupMetricsByMythId } from "@lib/dashboard/metrics";
import { buildMythContentMap } from "@lib/myth-content";
// Direct JSON import — Vite bundles the 79 KB into the prerender chunk at
// build time. The public copy at /data/carm-data.json stays put for the
// Daten-Explorer's runtime `fetch()`. Previously this used
// `readFile(new URL("../../../public/data/carm-data.json", import.meta.url))`
// which broke under Netlify's prerender step: after Vite bundling,
// `import.meta.url` points at .netlify/build/.prerender/chunks/index_*.mjs,
// so the relative walk-up resolved to a non-existent path.
import carmRawJson from "../../../public/data/carm-data.json";
import "../../styles/quiz.css";
// Brings in the .carm-filter-search-row* rules so the autocomplete
// search input on this page is the visually identical sibling of the
// Daten-Explorer filter drawer's search element. Lifted back in
// 2026-05-15 per Fedor's "same element as the search in the filter"
// note. If the Daten-Explorer search visual diverges later, fork
// these rules into quiz.css with a `.fakten-search-row__*` prefix.
import "../../styles/dashboard.css";

const groupMetricsByMyth = buildGroupMetricsByMythId(carmRawJson.metrics);

// Build myth ID → factsheet slug mapping
const factsheetEntries = await getPublishedEntries("zahlenUndFakten");

// Build the myths array for card display
const myths: {
  mythNumber: number;
  title: string;
  classification: string;
  classificationLabel: string;
  cardSummary: string;
  cardShortSummary: string;
  categoryGroup: string;
  slug: string;
}[] = [];

for (const [slug, entry] of factsheetEntries) {
  const e = entry as any;
  if (!e.mythNumber) continue;

  // Strip "Mythos XX:" or "Mythos XX/YY:" prefix and trailing terminal
  // punctuation (.!?) so consumers downstream — including any future
  // surface that bypasses VerdictStatement's splitForTail — get a clean
  // statement. VerdictStatement still strips trailing punctuation at
  // render time as a belt-and-braces.
  const rawTitle = e.title as string;
  const cleanTitle = rawTitle
    .replace(/^Mythos\s+\d+(?:\/\d+)?:\s*/i, "")
    .replace(/[.!?]+$/u, "");

  myths.push({
    mythNumber: e.mythNumber,
    title: cleanTitle,
    classification: e.classification || "",
    classificationLabel: e.classificationLabel || "",
    cardSummary: e.cardSummary || "",
    cardShortSummary: e.cardShortSummary || "",
    categoryGroup: e.categoryGroup || "",
    slug,
  });
}

// Sort myths by mythNumber ascending
myths.sort((a, b) => a.mythNumber - b.mythNumber);

// Pre-render factsheet HTML for the detail panel. Travel pipeline 4B/4C
// (2026-05-23) consolidated the per-callsite render-loop into the
// shared `buildMythContentMap` so the new `relatedMyths` + `faqBacklinks`
// fields stay populated identically across surfaces.
const mythContentMap = await buildMythContentMap();
---

<BaseLayout title="Fakten-Karten" description="42 Cannabis-Mythen — sofort erkennbar wahr oder falsch, mit wissenschaftlicher Einordnung.">
  <h1>Fakten-Karten</h1>
  <p>Stimmt das? 42 verbreitete Cannabis-Mythen, sofort eingeordnet — tippen Sie auf eine Karte für die Erklärung.</p>
  <FaktenKartenExplorer
    client:load
    myths={JSON.stringify(myths)}
    mythContent={JSON.stringify(mythContentMap)}
    groupMetrics={JSON.stringify(groupMetricsByMyth)}
  />
</BaseLayout>
