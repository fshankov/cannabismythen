---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { reader } from "@lib/content";
import { ScrollytellingViewer } from "@components/scrollytelling/ScrollytellingViewer";
import "../../styles/scrollytelling.css";
// #4 (2026-06-08): shared card chrome for Step 10's PathCards (same stylesheet
// the homepage FourPaths uses, so the two stay in sync).
import "../../styles/home-four-paths.css";

// Editorial German content lives in the Keystatic singleton; structural
// definitions (vizName, gridMode, …) live in stepDefinitions.ts. Heavy
// datasets (carm-data, information-sources) are fetched client-side by
// the React island from /data/.
const content = await reader.singletons.ueberUnsScrolly.read();
if (!content) {
  throw new Error(
    "ueberUnsScrolly singleton not found — check src/content/ueber-uns-scrolly.yaml",
  );
}

// Strip editorial-only field before passing to the client island.
const { internalNotes, ...publicContent } = content;
---

<BaseLayout
  title={publicContent.pageTitle}
  description={publicContent.pageDescription}
  hideFooter={true}
  extraBodyClass="scrolly-page"
>
  <ScrollytellingViewer client:load content={publicContent} />
  <noscript>
    <p style="padding: 24px; text-align: center; color: var(--color-text-secondary);">
      Diese Scrollytelling-Ansicht benötigt JavaScript. Bitte aktiviere
      JavaScript, um die Projektgeschichte zu lesen.
    </p>
  </noscript>
</BaseLayout>
