---
/**
 * 2026-05-14 rename — `/ueber-uns/` was renamed to `/projekt/` so the URL
 * matches the nav label "Über das Projekt" (and the mobile-tab-bar short
 * label "Projekt"). This stub preserves the query string when redirecting
 * and stays in place so external backlinks keep working.
 *
 * Defense in depth: edge middleware in `src/middleware.ts` short-circuits
 * before this fires for SSR; the prerendered static output lives here for
 * any path Netlify's static redirect rules miss.
 */
export const prerender = false;

const search = Astro.url.search;
return Astro.redirect(`/projekt/${search}`, 301);
---
