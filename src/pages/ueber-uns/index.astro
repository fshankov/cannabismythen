---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedEntries } from "@lib/content";

const entries = await getPublishedEntries("ueberUns");

// Sort by sortOrder
entries.sort((a, b) => {
  const orderA = (a[1] as any).sortOrder ?? 99;
  const orderB = (b[1] as any).sortOrder ?? 99;
  return orderA - orderB;
});
---

<BaseLayout title="Über das Projekt" description="Über das CaRM-Projekt, Methodik und das Team">
  <h1>Über das Projekt</h1>
  <p>
    Informationen zum CaRM-Forschungsprojekt, zur Methodik,
    zum Team und zum Klassifikationssystem.
  </p>

  <nav class="about-nav">
    {entries.map(([slug, entry]) => {
      const e = entry as any;
      return (
        <a href={`/ueber-uns/${slug}/`} class="about-card">
          <h2>{e.title}</h2>
          {e.summary && <p>{e.summary}</p>}
        </a>
      );
    })}
  </nav>
</BaseLayout>
