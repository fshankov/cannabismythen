---
export const prerender = true;

import Markdoc from "@markdoc/markdoc";
import BaseLayout from "@layouts/BaseLayout.astro";
import { reader } from "@lib/content";
import ScrollytellingViewer from "@components/scrollytelling/ScrollytellingViewer";

export async function getStaticPaths() {
  const slugs = await reader.collections.startseite.list();
  const paths = [];

  for (const slug of slugs) {
    const entry = await reader.collections.startseite.read(slug);
    if (entry && entry.status === "published") {
      paths.push({ params: { slug } });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const entry = await reader.collections.startseite.read(slug!);

if (!entry || entry.status !== "published") {
  return Astro.redirect("/");
}

const { content, internalNotes, ...meta } = entry;
const { node } = await content();
const html = Markdoc.renderers.html(Markdoc.transform(node));

// Build steps array for the interactive viewer
const scrollySteps = (meta.steps || []).map((s: any) => ({
  stepNumber: s.stepNumber,
  heading: s.heading,
  bodyText: s.bodyText,
  hint: s.hint || "",
  vizType: s.vizType,
  ctaLabel: s.ctaLabel || "",
  ctaUrl: s.ctaUrl || "",
}));
---

<BaseLayout title={meta.title} description={meta.summary || undefined}>
  <article class="scrollytelling-page">
    <header>
      <h1>{meta.title}</h1>
      {meta.versionLabel && <p class="version-label">Version {meta.versionLabel}</p>}
    </header>

    {scrollySteps.length > 0 ? (
      <ScrollytellingViewer
        steps={scrollySteps}
        title={meta.title}
        client:visible
      />
    ) : (
      <div class="scrollytelling-content" set:html={html} />
    )}

    <footer>
      <a href="/">&larr; Startseite</a>
    </footer>
  </article>
</BaseLayout>
