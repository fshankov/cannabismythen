---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedEntries } from "@lib/content";

const entries = await getPublishedEntries("quiz");

// Filter out feedback-texte for the quiz index (it's not a playable quiz)
const quizzes = entries.filter(([slug]) => slug !== "feedback-texte");
---

<BaseLayout title="Quiz" description="Testen Sie Ihr Wissen über Cannabis-Mythen">
  <h1>Quiz: Was wissen Sie über Cannabis?</h1>
  <p>
    Testen Sie Ihr Wissen in vier thematischen Quiz-Modulen.
    Jedes Quiz enthält Fragen zu verbreiteten Cannabis-Mythen mit
    wissenschaftlich fundierten Erklärungen.
  </p>

  <section class="quiz-selection">
    {quizzes.map(([slug, entry]) => {
      const e = entry as any;
      return (
        <a href={`/quiz/${slug}/`} class="quiz-card">
          <h2>{e.title}</h2>
          {e.questionCount > 0 && <p>{e.questionCount} Fragen</p>}
          {e.summary && <p>{e.summary}</p>}
        </a>
      );
    })}
  </section>
</BaseLayout>
