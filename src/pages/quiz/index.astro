---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedEntries } from "@lib/content";
import { getQuizThemeMeta } from "@lib/quiz/categories";
import "../../styles/quiz.css";

const entries = await getPublishedEntries("quiz");

// Filter out feedback-texte for the quiz index (it's not a playable quiz)
const quizzes = entries.filter(([slug]) => slug !== "feedback-texte");

// Remediation 6 — precompute per-tile values in the frontmatter (pure TS).
// Doing this inline inside the JSX expression confused Astro's template
// parser, which mis-read `i << s.length` and `(h << 5)` as JSX tags.
//
// Deck thickness ladder: ≤6 questions → 1 card behind, 7–9 → 2, ≥10 → 3.
// Idle tilt is a deterministic −1.6° to +1.6° per slug so the index reads
// as a hand-laid spread of cards, mirroring the in-quiz card's idle tilt.
function hashCode(input: string): number {
  let h = 0;
  for (let i = 0; i < input.length; i++) {
    h = (((h << 5) - h) + input.charCodeAt(i)) | 0;
  }
  return Math.abs(h);
}

const tiles = quizzes.map(([slug, entry]) => {
  const e = entry as { title: string; questionCount?: number };
  const meta = getQuizThemeMeta(slug as string);
  const count = (meta.count || e.questionCount || 7) as number;
  const deckDepth = count >= 10 ? 3 : count >= 7 ? 2 : 1;
  const tilt = ((hashCode(slug as string) % 1000) / 1000) * 3.2 - 1.6;
  return {
    slug: slug as string,
    title: e.title,
    Icon: meta.icon,
    strip: meta.strip,
    label: meta.label,
    count,
    deckDepth,
    tilt: tilt.toFixed(2),
    featured: Boolean(meta.featured),
  };
});
---

<BaseLayout
  title="Quiz"
  description="Teste dein Wissen über Cannabis-Mythen"
  ogImage="/og/quiz/index.png"
>
  <h1>Quiz: Was weißt du über Cannabis?</h1>

  <div class="quiz-index__intro">
    <p>
      Teste dein Wissen in fünf thematischen Quiz-Modulen oder im
      Schnellcheck mit zufälligen Aussagen aus allen Themen. Jede Aussage
      ist mit dem Stand der Forschung erklärt; deine Einschätzungen
      vergleichen wir mit denen der Erwachsenen (18–70) in einer
      Bevölkerungsbefragung in Deutschland.
    </p>
  </div>

  <section class="quiz-selection">
    {tiles.map((tile) => (
      <a
        href={`/quiz/${tile.slug}/`}
        class={`quiz-select-card ${tile.featured ? "quiz-select-card--featured" : ""}`}
        data-deck={tile.deckDepth}
        style={`--card-tilt: ${tile.tilt}deg; --tile-strip: ${tile.strip}; --tile-label: ${tile.label};`}
      >
        <span class="quiz-select-card__band" aria-hidden="true"></span>
        <span class="quiz-select-card__icon" aria-hidden="true">
          <tile.Icon size={44} strokeWidth={1.75} />
        </span>
        <h2 class="quiz-select-card__title">{tile.title}</h2>
        <span class="quiz-select-card__count">{tile.count} Fragen</span>
        {/* Stage A (2026-05-16) — band-color completion dot. Hidden by
            default; the inline script below reveals it once it finds a
            matching cm-quiz-score-{slug} entry in localStorage and
            derives the score band. */}
        <span
          class="quiz-select-card__band-dot"
          data-quiz-slug={tile.slug}
          aria-hidden="true"
        ></span>
        {tile.featured && (
          <span class="quiz-select-card__chip">Mix</span>
        )}
      </a>
    ))}
  </section>

  {/* Stage A — read each tile's last score from localStorage, derive the
      band (≥80 profi · ≥60 guterweg · ≥40 gehtnoch · else erwischt) and
      reveal a colored dot + tint the tile border. Per-browser only, no
      cookies. */}
  <script is:inline>
    (function () {
      if (typeof window === "undefined" || !window.localStorage) return;
      function bandFor(score) {
        if (score >= 80) return "profi";
        if (score >= 60) return "guterweg";
        if (score >= 40) return "gehtnoch";
        return "erwischt";
      }
      var dots = document.querySelectorAll(".quiz-select-card__band-dot");
      for (var i = 0; i < dots.length; i++) {
        var dot = dots[i];
        var slug = dot.getAttribute("data-quiz-slug");
        if (!slug) continue;
        try {
          var raw = window.localStorage.getItem("cm-quiz-score-" + slug);
          if (!raw) continue;
          var data = JSON.parse(raw);
          if (typeof data.moduleScore !== "number") continue;
          var band = bandFor(data.moduleScore);
          dot.setAttribute("data-band", band);
          dot.parentNode.setAttribute("data-band", band);
        } catch (e) {
          // ignore parse errors / disabled storage
        }
      }
    })();
  </script>
</BaseLayout>
