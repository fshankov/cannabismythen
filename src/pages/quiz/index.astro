---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedEntries } from "@lib/content";
import "../../styles/quiz.css";

const entries = await getPublishedEntries("quiz");

// Filter out feedback-texte for the quiz index (it's not a playable quiz)
const quizzes = entries.filter(([slug]) => slug !== "feedback-texte");

// Quiz card data: emoji + question count.
// Session 1 of 2026-05 — slugs renamed to match the docx 5-cat taxonomy
// (Kategorisierung_2026 05 06.docx). m03 moved from quiz-risiken to
// quiz-gefaehrlichkeit per the same docx, hence risiken 11→10 and
// gefaehrlichkeit 6→7.
const quizMeta: Record<string, { emoji: string; count: number; featured?: boolean }> = {
  "quiz-medizinischer-nutzen":  { emoji: "💊", count: 7  },
  "quiz-risiken-koerper-psyche": { emoji: "⚠️",  count: 10 },
  "quiz-stimmung-wahrnehmung":  { emoji: "🧠", count: 6  },
  "quiz-soziales-bevoelkerung": { emoji: "🏛️", count: 10 },
  "quiz-gefaehrlichkeit":       { emoji: "🚨",  count: 7  },
  // Stage 6 — Schnellcheck. Dynamic 7-myth deck, re-rolled per visit.
  "quiz-schnellcheck":          { emoji: "🎲", count: 7, featured: true },
};

// Remediation 6 — precompute per-tile values in the frontmatter (pure TS).
// Doing this inline inside the JSX expression confused Astro's template
// parser, which mis-read `i << s.length` and `(h << 5)` as JSX tags.
//
// Deck thickness ladder: ≤6 questions → 1 card behind, 7–9 → 2, ≥10 → 3.
// Idle tilt is a deterministic −1.6° to +1.6° per slug so the index reads
// as a hand-laid spread of cards, mirroring the in-quiz card's idle tilt.
function hashCode(input: string): number {
  let h = 0;
  for (let i = 0; i < input.length; i++) {
    h = (((h << 5) - h) + input.charCodeAt(i)) | 0;
  }
  return Math.abs(h);
}

const tiles = quizzes.map(([slug, entry]) => {
  const e = entry as { title: string; questionCount?: number };
  const meta = quizMeta[slug as string];
  const count = (meta?.count || e.questionCount || 7) as number;
  const deckDepth = count >= 10 ? 3 : count >= 7 ? 2 : 1;
  const tilt = ((hashCode(slug as string) % 1000) / 1000) * 3.2 - 1.6;
  return {
    slug: slug as string,
    title: e.title,
    emoji: meta?.emoji || "📋",
    count,
    deckDepth,
    tilt: tilt.toFixed(2),
    featured: Boolean(meta?.featured),
  };
});
---

<BaseLayout
  title="Quiz"
  description="Testen Sie Ihr Wissen über Cannabis-Mythen"
  ogImage="/og/quiz/index.png"
>
  <h1>Quiz: Was wissen Sie über Cannabis?</h1>

  <div class="quiz-index__intro">
    <p>
      Testen Sie Ihr Wissen in fünf thematischen Quiz-Modulen oder im
      Schnellcheck mit zufälligen Aussagen aus allen Themen. Jede Aussage
      ist mit dem Stand der Forschung erklärt; Ihre Einschätzungen
      vergleichen wir mit denen der Erwachsenen (18–70) in einer
      Bevölkerungsbefragung in Deutschland.
    </p>
  </div>

  <section class="quiz-selection">
    {tiles.map((tile) => (
      <a
        href={`/quiz/${tile.slug}/`}
        class={`quiz-select-card ${tile.featured ? "quiz-select-card--featured" : ""}`}
        data-deck={tile.deckDepth}
        style={`--card-tilt: ${tile.tilt}deg`}
      >
        <span class="quiz-select-card__emoji">{tile.emoji}</span>
        <h2 class="quiz-select-card__title">{tile.title}</h2>
        <span class="quiz-select-card__count">{tile.count} Fragen</span>
        {/* BugHerd #37b (Session 3b, 2026-05-07): per-tile last-score
            chip. Hidden until the inline script below finds a matching
            cm-quiz-score-{slug} entry in localStorage and fills it in. */}
        <span
          class="quiz-select-card__last-score"
          data-quiz-slug={tile.slug}
          aria-live="polite"
        ></span>
        {tile.featured && (
          <span class="quiz-select-card__chip">Mix</span>
        )}
      </a>
    ))}
  </section>

  {/* BugHerd #37b — read each tile's last score from localStorage and
      render it as a small chip below the question count. Inline so it
      runs before the user can scroll; per-browser only, no cookies. */}
  <script is:inline>
    (function () {
      if (typeof window === "undefined" || !window.localStorage) return;
      var nodes = document.querySelectorAll("[data-quiz-slug]");
      for (var i = 0; i < nodes.length; i++) {
        var el = nodes[i];
        var slug = el.getAttribute("data-quiz-slug");
        if (!slug) continue;
        try {
          var raw = window.localStorage.getItem("cm-quiz-score-" + slug);
          if (!raw) continue;
          var data = JSON.parse(raw);
          if (
            typeof data.moduleScore !== "number" ||
            typeof data.correctCount !== "number" ||
            typeof data.totalQuestions !== "number"
          ) continue;
          var pct = Math.round(data.moduleScore);
          el.textContent =
            "Zuletzt: " + data.correctCount + "/" + data.totalQuestions +
            " · " + pct + " %";
          el.classList.add("quiz-select-card__last-score--has-data");
        } catch (e) {
          // ignore parse errors / disabled storage
        }
      }
    })();
  </script>
</BaseLayout>
