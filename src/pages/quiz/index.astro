---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedEntries } from "@lib/content";
import { getQuizThemeMeta } from "@lib/quiz/categories";
import { QUIZ_THEMES } from "../../components/quiz/quizData";
import { t } from "../../components/quiz/i18n";
import { Send } from "lucide-react";
import "../../styles/quiz.css";

const entries = await getPublishedEntries("quiz");

// Filter out feedback-texte for the quiz index (it's not a playable quiz)
const quizzes = entries.filter(([slug]) => slug !== "feedback-texte");

const tiles = quizzes.map(([slug, entry]) => {
  const e = entry as { title: string; questionCount?: number };
  const meta = getQuizThemeMeta(slug as string);
  const count = (meta.count || e.questionCount || 7) as number;
  // Tile uses the short title from QUIZ_THEME_META; entry.title is the
  // long descriptive form used on the quiz play screen and OG images.
  const title = meta.shortTitle || e.title;
  // 2026-05-28 (CAR-5) — framing question that previously lived on the
  // TitleCard now surfaces on the tile (hover reveal on desktop,
  // always visible on mobile). Source: QUIZ_THEMES[slug].subtitleKey
  // resolved through the same i18n table the in-quiz UI reads.
  const subtitleKey = QUIZ_THEMES[slug as string]?.subtitleKey;
  const framingQuestion = subtitleKey ? t(subtitleKey) : "";
  // Minute estimate — matches the pre-CAR-5 TitleCard calculation
  // (Math.round(count * 0.5), floor 1) so existing user expectations
  // around "ca. 4 Min." don't shift.
  const minutes = Math.max(1, Math.round(count * 0.5));
  return {
    slug: slug as string,
    title,
    Icon: meta.icon,
    theme: meta.theme,
    count,
    framingQuestion,
    minutes,
  };
});
---

<BaseLayout
  title="Quiz"
  description="Teste dein Wissen über Cannabis-Mythen"
  ogImage="/og/quiz/index.png"
  bgTexture
>
  <h1 class="quiz-index__title">Quiz: Was weißt du über Cannabis?</h1>

  <div class="quiz-index__intro">
    <p>
      Teste dein Wissen in fünf thematischen Quiz-Modulen oder im
      Schnellcheck mit zufälligen Mythen aus allen Themen. Jeder Mythos
      ist mit dem Stand der Forschung erklärt; deine Einschätzungen
      vergleichen wir mit denen der Erwachsenen (18–70) in einer
      Bevölkerungsbefragung in Deutschland.
    </p>
  </div>

  <p class="quiz-index__category-label">Wählen Sie eine Kategorie aus</p>

  <section class="quiz-selection">
    {tiles.map((tile) => (
      <a
        href={`/quiz/${tile.slug}/`}
        class={`quiz-select-card quiz-select-card--${tile.theme}`}
        aria-label={`Quiz starten: ${tile.title}`}
      >
        <span class="quiz-select-card__orb" aria-hidden="true"></span>

        {tile.theme === "gradient" && (
          <span class="quiz-select-card__mix" aria-hidden="true">MIX</span>
        )}

        <div class="quiz-select-card__content">
          <span class="quiz-select-card__icon" aria-hidden="true">
            <tile.Icon size={56} strokeWidth={1.75} />
          </span>
          <h2 class="quiz-select-card__title">{tile.title}</h2>
          {/* 2026-05-28 (CAR-5) — framing question (desktop hover /
              mobile always). Replaces the prior AI-drafted
              "Fragen, die deine Perspektive…" subline. */}
          <p class="quiz-select-card__framing">{tile.framingQuestion}</p>
        </div>

        {/* 2026-05-29 (Fedor) — meta line centered directly above the
            CTA button, always visible on every card. */}
        <p class="quiz-select-card__meta">
          {tile.count} Mythen · ca. {tile.minutes} Min.
        </p>

        <span class="quiz-select-card__cta" aria-hidden="true">
          <span class="quiz-select-card__cta-text">QUIZ STARTEN</span>
          <span class="quiz-select-card__cta-icon">
            <Send size={20} strokeWidth={1.75} />
          </span>
        </span>
      </a>
    ))}
  </section>
</BaseLayout>
