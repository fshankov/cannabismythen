---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { reader } from "@lib/content";
import QuizPlayer from "@components/quiz/QuizPlayer";
import { QUIZ_THEMES } from "@components/quiz/quizData";
import type { MythGroupMetrics } from "@lib/dashboard/types";
import type { MythContentEntry } from "@components/shared/FactsheetPanel";
import { buildGroupMetricsByMythId } from "@lib/dashboard/metrics";
import { buildMythContentMapByMythId } from "@lib/myth-content";
// Direct JSON import — see fakten-karten/index.astro for the rationale.
// `readFile(new URL(..., import.meta.url))` resolves wrong after Vite
// bundles this page into Netlify's prerender chunk.
import carmRawJson from "../../../public/data/carm-data.json";
import "../../styles/quiz.css";

const groupMetricsByMythId = buildGroupMetricsByMythId(carmRawJson.metrics);

// mythNumber → text_short_de (ultra-short Daten-Explorer label, e.g.
// "Allheilmittel"). Mirrors fakten-karten/index.astro so the wrong-myths
// FaktenCard on the result page shows the short label on its back-face
// headline instead of falling back to the long statement — keeping the
// quiz cards format-identical to the /fakten-karten/ page.
const shortLabelByMythNumber = new Map<number, string>();
for (const m of carmRawJson.myths as Array<{ id: number; text_short_de: string }>) {
  if (typeof m.text_short_de === "string" && m.text_short_de.length > 0) {
    shortLabelByMythNumber.set(m.id, m.text_short_de);
  }
}

export async function getStaticPaths() {
  const slugs = await reader.collections.quiz.list();
  const paths = [];

  for (const slug of slugs) {
    const entry = await reader.collections.quiz.read(slug);
    if (entry && entry.status === "published" && slug !== "feedback-texte") {
      paths.push({ params: { slug } });
    }
  }

  return paths;
}

const { slug } = Astro.params;
const entry = await reader.collections.quiz.read(slug!);

if (!entry || entry.status !== "published") {
  return Astro.redirect("/quiz/");
}

// Build quiz text map from Keystatic-editable questions (statement + explanation)
const quizTextMap: Record<string, { statement: string; explanation: string }> = {};
if (entry.questions) {
  for (const q of entry.questions) {
    if (q.mythId && q.statement) {
      quizTextMap[q.mythId] = {
        statement: q.statement,
        explanation: q.explanation || "",
      };
    }
  }
}

// ── Editorial verdicts + intros + shareCopy (Keystatic source of truth,
// see CLAUDE.md "Quiz content source of truth" section). Stage 5 consumes
// verdicts/intros on the ResultScreen; Stage 7 adds shareCopy with
// per-module override → global singleton default → hardcoded fallback.
const entryAny = entry as unknown as {
  verdicts?: {
    profi?: { title?: string; body?: string };
    guterweg?: { title?: string; body?: string };
    gehtnoch?: { title?: string; body?: string };
    erwischt?: { title?: string; body?: string };
  };
  weakSpotIntro?: string;
  strongPerformanceIntro?: string;
  shareCopy?: {
    profi?: string;
    guterweg?: string;
    gehtnoch?: string;
    erwischt?: string;
  };
};
const verdictsPayload = entryAny.verdicts ?? {};
const introsPayload = {
  weakSpotIntro: entryAny.weakSpotIntro ?? "",
  strongPerformanceIntro: entryAny.strongPerformanceIntro ?? "",
};

// Stage 7 — merge per-module shareCopy override with the global default
// singleton. Module's non-empty value wins; empty/missing → singleton;
// singleton missing → hardcoded fallback in ResultScreen as final defence.
const defaultShareCopy = await reader.singletons.shareCopy.read();
const moduleOverrides = entryAny.shareCopy ?? {};
const sharePayload = {
  profi:
    (moduleOverrides.profi || defaultShareCopy?.profi || "").trim(),
  guterweg:
    (moduleOverrides.guterweg || defaultShareCopy?.guterweg || "").trim(),
  gehtnoch:
    (moduleOverrides.gehtnoch || defaultShareCopy?.gehtnoch || "").trim(),
  erwischt:
    (moduleOverrides.erwischt || defaultShareCopy?.erwischt || "").trim(),
};

// Pre-render myth page content for the factsheet panel. Travel pipeline
// 4B/4C (2026-05-23) — the popup data shape is now built once in
// `buildMythContentMapByMythId` (includes relatedMyths + faqBacklinks),
// then this loop just narrows to the theme's myths and stays in charge
// of the quiz-only sibling maps (quizGroupMetricsMap, quizTextMap
// overlay, quizFaktenContentMap).
const theme = QUIZ_THEMES[slug!];
const allMythContent = await buildMythContentMapByMythId();
const mythContentMap: Record<string, MythContentEntry> = {};
// Per-quiz-myth-id metrics map. The quiz uses string IDs ("m01"), so we
// re-key the numeric carm-data map into the same shape QuizPlayer's
// content map already uses.
const quizGroupMetricsMap: Record<string, MythGroupMetrics> = {};
// Stage E commit 4 (2026-05-23): per-quiz-myth-id fakten-karten data
// for the wrong-myths grid on the result page. Mirrors the
// FaktenCardMyth shape consumed by `src/components/fakten-karten/
// FaktenCard.tsx`, plus the `categoryGroup` field needed for the
// card's category footer + stripe color. Built from the same
// `reader.collections.zahlenUndFakten.read()` call below; no extra
// I/O per myth.
const quizFaktenContentMap: Record<
  string,
  {
    mythNumber: number;
    title: string;
    shortLabel: string;
    classification: string;
    classificationLabel: string;
    cardSummary: string;
    cardShortSummary: string;
    slug: string;
    categoryGroup: string;
  }
> = {};

if (theme) {
  for (const myth of theme.myths) {
    try {
      const mythEntry = await reader.collections.zahlenUndFakten.read(myth.mythPageSlug);
      if (mythEntry) {
        // Strip "Mythos N:" / "Mythos N/M:" prefix AND trailing terminal
        // punctuation (.!?) so the popup heading reads as a clean
        // statement. Kept inline for the quiz-only `quizFaktenContentMap`
        // below that needs the cleaned title alongside other myth fields.
        const rawMythTitle = mythEntry.title as string;
        const cleanMythTitle = rawMythTitle
          .replace(/^Mythos\s+\d+(?:\/\d+)?:\s*/i, "")
          .replace(/[.!?]+$/u, "");

        // Popup content (html + title + classification + related/backlinks)
        // comes from the pre-built map. Falling back to a minimal inline
        // entry is unnecessary — buildMythContentMapByMythId covers every
        // published myth, so a miss means the .mdoc is unpublished or
        // mythId is missing, in which case the popup couldn't open anyway.
        if (allMythContent[myth.id]) {
          mythContentMap[myth.id] = allMythContent[myth.id];
        }

        // Overlay the ISD-finalised cardShortSummary onto the reveal
        // card's explanation. Quiz mdoc's `explanation` stays as the
        // fallback for myths where the new summary hasn't been added
        // yet (and is preserved in the schema for archival reasons).
        const mythCardShortSummary = (mythEntry as { cardShortSummary?: string }).cardShortSummary;
        if (mythCardShortSummary && quizTextMap[myth.id]) {
          quizTextMap[myth.id] = {
            ...quizTextMap[myth.id],
            explanation: mythCardShortSummary,
          };
        }

        // mNN → numeric id ("m01" → 1). The mythNumber field on the
        // .mdoc is the canonical conversion; falling back to a regex on
        // the id keeps things safe if the field is somehow missing.
        const mythNumber =
          (mythEntry as { mythNumber?: number }).mythNumber ??
          Number(myth.id.replace(/[^0-9]/g, ""));
        if (Number.isFinite(mythNumber) && groupMetricsByMythId[mythNumber]) {
          quizGroupMetricsMap[myth.id] = groupMetricsByMythId[mythNumber];
        }

        // Stage E commit 4 — assemble FaktenCard payload for the
        // wrong-myths grid on the quiz result page. Pulls all fields
        // from the same `mythEntry` already loaded above so this adds
        // no extra Keystatic round-trips.
        const mythEntryAny = mythEntry as {
          cardSummary?: string;
          cardShortSummary?: string;
          categoryGroup?: string;
        };
        quizFaktenContentMap[myth.id] = {
          mythNumber: Number.isFinite(mythNumber) ? mythNumber : 0,
          title: cleanMythTitle,
          // Back-face headline: short Daten-Explorer label, same source the
          // /fakten-karten/ page uses. Falls back to the cleaned full title
          // (matches index.astro:72) if a myth has no text_short_de.
          shortLabel: shortLabelByMythNumber.get(mythNumber) ?? cleanMythTitle,
          classification: mythEntry.classification as string,
          classificationLabel: mythEntry.classificationLabel as string,
          cardSummary: mythEntryAny.cardSummary ?? "",
          cardShortSummary: mythEntryAny.cardShortSummary ?? "",
          slug: myth.mythPageSlug,
          categoryGroup: mythEntryAny.categoryGroup ?? "",
        };
      }
    } catch {
      // If a myth page doesn't exist or fails to render, skip it
    }
  }
}
---

<BaseLayout
  title={entry.title}
  description={entry.summary || "Cannabis-Quiz: Testen Sie Ihr Wissen"}
  ogImage={`/og/quiz/${slug}.png`}
  bgTexture
>
  <div class="quiz-loader-wrap">
    <div class="quiz-loader" aria-hidden="true">
      <div class="quiz-loader__grid">
        <span class="quiz-loader__btn quiz-loader__btn--richtig">
          <svg width="30" height="22" viewBox="0 0 30 22" fill="none"><path d="M28.2041 1.39285L1.3916 1.39286" stroke="#A7D3C5" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/><path d="M14.7979 20.1604L14.7978 1.39168" stroke="#047857" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/><path d="M24.1826 10.7776L14.7982 1.39324L5.41386 10.7776" stroke="#047857" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="quiz-loader__btn quiz-loader__btn--eher_falsch">
          <svg width="34" height="34" viewBox="0 0 34 34" fill="none"><path d="M32.2303 13.271L13.271 32.2303" stroke="#E0B58D" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.47932 9.47998L22.7508 22.7515" stroke="#B45309" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/><path d="M22.7508 9.47803V22.7495H9.47929" stroke="#B45309" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="quiz-loader__btn quiz-loader__btn--eher_richtig">
          <svg width="34" height="34" viewBox="0 0 34 34" fill="none"><path d="M32.2303 20.351L13.271 1.39168" stroke="#C2D3A3" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/><path d="M9.47932 24.142L22.7508 10.8705" stroke="#4D7C0F" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/><path d="M22.7508 24.144V10.8724H9.47929" stroke="#4D7C0F" stroke-width="2.78" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="quiz-loader__btn quiz-loader__btn--falsch">
          <svg width="26" height="22" viewBox="0 0 26 22" fill="none"><path d="M1.2666 18.8793C0.567207 18.8798 0 19.4464 0 20.1459C0 20.8454 0.567207 21.4121 1.2666 21.4125L24.2705 21.4125C24.9703 21.4125 25.5371 20.8457 25.5371 20.1459C25.5371 19.4462 24.9703 18.8793 24.2705 18.8793L1.2666 18.8793Z" fill="#E9A8B9"/><path d="M12.771 1.26703L12.771 19.3997" stroke="#BE123C" stroke-width="2.53" stroke-linecap="round" stroke-linejoin="round"/><path d="M20.8223 10.3315L12.771 19.3978L4.71974 10.3315" stroke="#BE123C" stroke-width="2.53" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </div>
    </div>
    <article class="quiz-page" data-reveal-fade>
      <QuizPlayer
        client:only="react"
        quizSlug={slug!}
        mythContent={JSON.stringify(mythContentMap)}
        groupMetrics={JSON.stringify(quizGroupMetricsMap)}
        quizText={JSON.stringify(quizTextMap)}
        verdicts={JSON.stringify(verdictsPayload)}
        intros={JSON.stringify(introsPayload)}
        shareCopy={JSON.stringify(sharePayload)}
        faktenContent={JSON.stringify(quizFaktenContentMap)}
        quizSummary={(entry as any).summary || undefined}
      />
      <noscript>
        <p style="padding: 24px; text-align: center; color: var(--color-text-secondary);">
          Das Quiz benötigt JavaScript. Bitte aktiviere JavaScript, um zu
          starten.
        </p>
      </noscript>
    </article>
  </div>
</BaseLayout>

<style>
  .quiz-loader-wrap {
    position: relative;
  }
  .quiz-loader {
    position: fixed;
    inset: 0;
    z-index: 98;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg, #faf9f5);
    animation: quiz-loader-exit 0.7s ease forwards;
    animation-delay: 1.55s;
  }
  .quiz-loader__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }
  .quiz-loader__btn {
    width: 88px;
    height: 88px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    border: 3px solid transparent;
    /* pop-in then jump */
    opacity: 0;
    transform: scale(0.25);
    animation:
      quiz-btn-pop 0.42s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
      quiz-btn-jump 0.32s cubic-bezier(0.22, 1, 0.36, 1) 0.85s both;
  }
  .quiz-loader__btn svg { display: block; }

  .quiz-loader__btn--richtig    { background: #d1e8d1; animation-delay: 0.08s, 0.85s; }
  .quiz-loader__btn--eher_falsch { background: #ffefbc; animation-delay: 0.16s, 0.93s; }
  .quiz-loader__btn--eher_richtig{ background: #e1ebe2; animation-delay: 0.24s, 1.01s; }
  .quiz-loader__btn--falsch      { background: #ffe9ed; animation-delay: 0.32s, 1.09s; }


  @keyframes quiz-btn-pop {
    from { opacity: 0; transform: scale(0.25); }
    to   { opacity: 1; transform: scale(1); }
  }
  @keyframes quiz-btn-jump {
    0%  { transform: translateY(0); }
    45% { transform: translateY(-14px); }
    100%{ transform: translateY(0); }
  }
  @keyframes quiz-loader-exit {
    to { opacity: 0; visibility: hidden; }
  }

  @media (prefers-reduced-motion: reduce) {
    .quiz-loader__btn {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .quiz-loader {
      animation-delay: 0.6s;
    }
  }
</style>
