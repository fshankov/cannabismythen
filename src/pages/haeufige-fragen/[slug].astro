---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedEntries } from "@lib/content";
import {
  getAudience,
  getQuestionsByAudience,
  VALID_AUDIENCES,
  type FaqAudienceId,
} from "@lib/faq";
import AudienceHeader from "@components/faq/AudienceHeader.astro";
import FaqQuestionComponent from "@components/faq/FaqQuestion.astro";
import HelplineBox from "@components/faq/HelplineBox.astro";
import WeiterfuehrendList from "@components/faq/WeiterfuehrendList.astro";

// Legacy theme slugs (`/haeufige-fragen/gesundheit/`, etc.) are redirected to
// the appropriate audience page via `astro.config.mjs#redirects`.

export async function getStaticPaths() {
  // Inline list intentional: Astro hoists getStaticPaths into a separate
  // scope where module-level frontmatter constants are not available.
  const ids: FaqAudienceId[] = [
    "eltern",
    "jugendliche",
    "konsumierende",
    "lehrkraefte",
    "fachkraefte",
  ];
  return ids.map((id) => ({ params: { slug: id } }));
}

const { slug } = Astro.params;

if (!VALID_AUDIENCES.includes(slug as FaqAudienceId)) {
  return Astro.redirect("/haeufige-fragen/");
}

const audience = await getAudience(slug as FaqAudienceId);
if (!audience) return Astro.redirect("/haeufige-fragen/");

const questions = await getQuestionsByAudience(slug as FaqAudienceId);

// Pre-compute quiz titles for the related rail.
const quizTitles: Record<string, string> = {};
const quizEntries = await getPublishedEntries("quiz");
for (const [qSlug, e] of quizEntries) {
  const title = (e as { title?: string }).title;
  if (title) quizTitles[qSlug] = title;
}

const pageTitle = audience.title;
const pageDescription = audience.description;
---

<BaseLayout title={pageTitle} description={pageDescription || undefined}>
  <article class="faq-audience-page" data-audience={audience.id}>
    <AudienceHeader audience={audience} questionCount={questions.length} />

    {questions.length > 1 && (
      <nav class="faq-toc" aria-label="Inhaltsübersicht">
        <p class="faq-toc__label">Auf dieser Seite ({questions.length}):</p>
        <ul class="faq-toc__list">
          {questions.map((q, i) => (
            <li>
              <a href={`#faq-${q.slug}`}>
                <span class="faq-toc__num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
                {q.questionLong}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="faq-audience-questions">
      {questions.map((q, i) => (
        <FaqQuestionComponent
          question={q}
          index={i + 1}
          open={i === 0}
          quizTitles={quizTitles}
        />
      ))}
    </div>

    {audience.helplines.length > 0 && (
      <div class="faq-audience-helplines">
        <h2 class="faq-audience-helplines__heading">Hilfeangebote</h2>
        <div class="faq-audience-helplines__list">
          {audience.helplines.map((h) => (
            <HelplineBox helpline={h} variant="footer" />
          ))}
        </div>
      </div>
    )}

    <WeiterfuehrendList items={audience.weiterfuehrend} />

    <footer class="faq-audience-page__footer">
      <a href="/haeufige-fragen/">← Alle Zielgruppen</a>
    </footer>
  </article>
</BaseLayout>

<script is:inline>
  // Open the <details> matching the URL hash on first paint.
  (function () {
    function openByHash() {
      var hash = window.location.hash.replace(/^#/, "");
      if (!hash) return;
      var el = document.getElementById(hash);
      if (el && el.tagName === "ARTICLE") {
        var d = el.querySelector("details");
        if (d) d.open = true;
        el.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }
    openByHash();
    window.addEventListener("hashchange", openByHash);
  })();
</script>
