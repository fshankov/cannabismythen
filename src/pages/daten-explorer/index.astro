---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import MythenExplorer from "@components/dashboard/MythenExplorer";
import { getPublishedEntries } from "@lib/content";
import { buildMythContentMap } from "@lib/myth-content";
// Dashboard definitions — loaded at build time from Keystatic singleton.
// Edit via /keystatic (Dashboard – Definitionen & Glossar) → commit to
// content/ branch → Netlify rebuilds → tooltips show updated text.
import definitionsData from "../../content/dashboard-definitionen.json";
import "../../styles/dashboard.css";
import IconClusterIllustration from "@components/home/IconClusterIllustration.astro";

// Build mythId → Quiz theme slug map. Each quiz module mdoc lists
// the myth IDs it covers via questions[].mythId (format "m04"). We map the
// numeric myth_id ("m04" → 4) to the theme slug ("quiz-gefaehrlichkeit").
// The Streifen view uses this for the Themen filter / Themen pivot mode.
const quizEntries = await getPublishedEntries("quiz");
const mythIdToTheme: Record<number, string> = {};
for (const [slug, entry] of quizEntries) {
  if (slug === "feedback-texte") continue;
  const e = entry as any;
  const questions = (e.questions || []) as Array<{ mythId?: string }>;
  for (const q of questions) {
    if (!q.mythId) continue;
    const num = parseInt(q.mythId.replace(/[^\d]/g, ""), 10);
    if (Number.isFinite(num)) mythIdToTheme[num] = slug;
  }
}

// Build myth ID → factsheet slug mapping
const factsheetEntries = await getPublishedEntries("zahlenUndFakten");
const mythSlugs: Record<number, string> = {};

for (const [slug, entry] of factsheetEntries) {
  const e = entry as any;
  if (e.mythNumber) {
    mythSlugs[e.mythNumber] = slug;
  }
}

// Pre-render factsheet HTML for the detail panel. Travel pipeline 4B/4C
// (2026-05-23) consolidated the per-callsite render-loop into
// `buildMythContentMap` so the new `relatedMyths` + `faqBacklinks`
// fields stay populated identically across Daten-Explorer, Fakten-Karten,
// Quiz, and Meine Interessen.
const mythContentMap = await buildMythContentMap();
---

<BaseLayout
  title="Daten-Explorer"
  description="Interaktive Datenvisualisierung zu 42 Cannabis-Mythen — Erkunden Sie wissenschaftliche Einordnungen, Bevölkerungsdaten und Indikatoren."
  bgTexture
>
  <script is:inline>
    if ("scrollRestoration" in history) history.scrollRestoration = "manual";
    try {
      window.scrollTo(0, 0);
    } catch (_) {}
  </script>
  <header class="carm-explorer__page-header" data-reveal>
    <h1 class="carm-explorer__page-header__h1">Daten-Explorer</h1>
    <p class="carm-explorer__page-header__sub">
      Hier erkundest du die Daten der CaRM-Studie, 2025 in Deutschland erhoben.<br
      />
      <strong>Neu hier?</strong> Der <strong>Rundgang</strong>
      <svg
        class="carm-rundgang-bookmark-inline"
        viewBox="0 0 40 52"
        aria-hidden="true"
        focusable="false"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M8 0 H32 A8 8 0 0 1 40 8 V52 L20 40 L0 52 V8 A8 8 0 0 1 8 0 Z"
          style="fill: var(--color-accent)"></path>
        <text
          x="20"
          y="20"
          text-anchor="middle"
          dominant-baseline="central"
          font-size="23"
          font-weight="800"
          fill="#ffffff"
          font-family="'Inter Variable', 'Inter', system-ui, sans-serif">?</text
        >
      </svg>
      führt dich in etwa einer Minute durch den Explorer.<br />
      Wie die Daten entstanden sind, erfährst du in <a href="/projekt/"
        >„Über das Projekt"</a
      >.
    </p>
  </header>
  <div class="de-loader-wrap">
    <div class="de-loader" aria-hidden="true">
      <IconClusterIllustration size={180} loaderMode />
      <p class="de-loader__text">Daten werden geladen …</p>
    </div>
    <div data-reveal-fade>
      <MythenExplorer
        client:load
        mythSlugs={mythSlugs}
        mythContent={JSON.stringify(mythContentMap)}
        definitions={JSON.stringify(definitionsData)}
        mythThemes={JSON.stringify(mythIdToTheme)}
      />
      <noscript>
        <p
          style="padding: 24px; text-align: center; color: var(--color-text-secondary);"
        >
          Der Daten-Explorer benötigt JavaScript. Ohne JavaScript stehen
          einzelne Faktenblätter über die Navigation zur Verfügung.
        </p>
      </noscript>
    </div>
  </div>

  <script is:inline>
    /* Feedbucket screenshot fix: this loader hides via a CSS animation whose
       `forwards` end-state isn't reproduced when Feedbucket clones the DOM for
       its screenshot, so the finished loader re-appears in captures even though
       it's invisible on the live page. After the exit animation ends, drop it
       from rendering with an inline display:none (which the DOM clone respects).
       The animation is untouched; the timeout is a safety net in case
       animationend never fires (e.g. animations globally disabled). */
    (function () {
      var el = document.querySelector(".de-loader");
      if (!el) return;
      var hidden = false;
      function clear() {
        if (hidden) return;
        hidden = true;
        el.style.display = "none";
      }
      // Only the loader's OWN exit animation — child entrance animations
      // (cluster nodes/links, the infinite breathe) bubble animationend too.
      el.addEventListener("animationend", function (e) {
        if (e.target === el) clear();
      });
      setTimeout(clear, 3500); // well after the ~2.55s exit completes
    })();
  </script>
</BaseLayout>

<style>
  .de-loader-wrap {
    position: relative;
  }
  .de-loader {
    position: fixed;
    inset: 0;
    z-index: 9998;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-bg, #faf9f5);
    animation: de-loader-exit 0.8s ease forwards;
    animation-delay: 1.75s;
    pointer-events: none;
  }
  .de-loader__text {
    margin-top: 32px;
    margin-bottom: 0;
    font-size: 16px;
    color: var(--color-text-secondary, #64748b);
  }
  @keyframes de-loader-exit {
    to {
      opacity: 0;
      visibility: hidden;
    }
  }
  /* Keep nav above the loader */
  :global(.nav-wrapper) {
    z-index: 9999;
  }
  /* Hide feedbucket footer until loader is gone */
  :global(.feedbucket-footer) {
    visibility: hidden;
    animation: de-fb-show 0s 2.6s linear forwards;
  }
  @keyframes de-fb-show {
    to {
      visibility: visible;
    }
  }
</style>
