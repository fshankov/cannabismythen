---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import AudienceHubGrid from "@components/faq/AudienceHubGrid.astro";
import {
  getAllAudiences,
  getQuestionsByAudience,
  type FaqAudienceMeta,
  type FaqQuestion,
} from "@lib/faq";

// Quiz-deck tile styles (.quiz-selection / .quiz-select-card / deck
// pseudo-elements / mobile snap-carousel). AudienceHubGrid layers a
// small set of `.mi-hub-card` overrides on top.
import "../../styles/quiz.css";

const audiences = await getAllAudiences();

const items: { audience: FaqAudienceMeta; count: number; topQuestion: FaqQuestion | null }[] =
  [];

for (const audience of audiences) {
  const questions = await getQuestionsByAudience(audience.id);
  items.push({
    audience,
    count: questions.length,
    topQuestion: questions[0] ?? null,
  });
}
---

<BaseLayout
  title="Meine Interessen"
  description="Antworten zugeschnitten auf deine Lebenssituation — Eltern, Jugendliche, Konsumierende, Lehrkräfte, Fachkräfte."
  bgTexture
>
  <section class="faq-hub" aria-labelledby="faq-hub-h1">
    <div class="faq-hub__intro">
      <h1 id="faq-hub-h1" class="faq-hub__title">Meine Interessen</h1>
      <p class="faq-hub__subtitle">
        Wähle deine Perspektive und erhalte gezielte Antworten auf Cannabis-Mythen — zugeschnitten auf deine Lebenssituation.
      </p>
    </div>

    <AudienceHubGrid items={items} />

    <details class="faq-hub__methode">
      <summary>Methodische Anmerkung</summary>
      <p>
        Die FAQ-Antworten auf dieser Seite basieren auf den Daten der CaRM-Studie
        („Cannabiskonsum – Risiken und Mythen in Deutschland"), durchgeführt 2024–2025.
        Befragt wurden in drei Panels 2.097 Volljährige (18–70 J.), 555 Minderjährige
        (16–17 J.) sowie 143 Cannabis-Konsument:innen in Deutschland. Mythen wurden auf
        einer vierstufigen Skala wissenschaftlich klassifiziert: richtig, eher richtig,
        eher falsch oder falsch. Prozentangaben und Punktewerte (0–100) beziehen sich
        auf die jeweilige Zielgruppe.
      </p>
    </details>
  </section>
</BaseLayout>
