---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import AudienceHubGrid from "@components/faq/AudienceHubGrid.astro";
import {
  getAllAudiences,
  getQuestionsByAudience,
  type FaqAudienceMeta,
  type FaqQuestion,
} from "@lib/faq";

// Quiz-deck tile styles (.quiz-selection / .quiz-select-card / deck
// pseudo-elements / mobile snap-carousel). AudienceHubGrid layers a
// small set of `.mi-hub-card` overrides on top.
import "../../styles/quiz.css";

const audiences = await getAllAudiences();

const items: { audience: FaqAudienceMeta; count: number; topQuestion: FaqQuestion | null }[] =
  [];

for (const audience of audiences) {
  const questions = await getQuestionsByAudience(audience.id);
  items.push({
    audience,
    count: questions.length,
    topQuestion: questions[0] ?? null,
  });
}
---

<BaseLayout
  title="Meine Interessen"
  description="Antworten zugeschnitten auf Ihre Lebenssituation — Eltern, Jugendliche, Konsumierende, Lehrkräfte, Fachkräfte."
>
  <section class="faq-hub" aria-labelledby="faq-hub-h1">
    {/* Heading is rendered for accessibility but visually hidden — the
        audience cards themselves communicate the page's purpose. */}
    <h1 id="faq-hub-h1" class="sr-only">Meine Interessen</h1>

    <AudienceHubGrid items={items} />

    <details class="faq-hub__methode">
      <summary>Methodische Anmerkung</summary>
      <p>
        Die FAQ-Antworten basieren auf den Daten der CaRM-Studie (Cannabis-bezogene
        Auffassungen und Risikowahrnehmung in Deutschland), durchgeführt 2022–2023.
        Befragt wurden 2.097 Volljährige (18–70 J.), 555 Minderjährige (16–17 J.) und
        143 aktuelle Cannabis-Konsumierende. Alle Mythen wurden durch eine systematische
        Literaturanalyse wissenschaftlich klassifiziert (richtig · eher richtig · eher falsch
        · falsch). Alle Prozentzahlen und Punktewerte entstammen direkt den Studiendaten.
      </p>
    </details>
  </section>
</BaseLayout>
