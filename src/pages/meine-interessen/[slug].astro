---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import MeineInteressenAudience from "@components/faq/MeineInteressenAudience.astro";
import { getAudience, VALID_AUDIENCES, type FaqAudienceId } from "@lib/faq";

// Legacy theme slugs (`/meine-interessen/gesundheit/`, etc.) are redirected to
// the appropriate audience page via `astro.config.mjs#redirects`.

export async function getStaticPaths() {
  return VALID_AUDIENCES.map((id) => ({ params: { slug: id } }));
}

const { slug } = Astro.params;

if (!VALID_AUDIENCES.includes(slug as FaqAudienceId)) {
  return Astro.redirect("/meine-interessen/");
}

const audience = await getAudience(slug as FaqAudienceId);
if (!audience) return Astro.redirect("/meine-interessen/");
---

<BaseLayout title={audience.title} description={audience.description || undefined} bgTexture extraBodyClass="mi-page">
  <MeineInteressenAudience slug={slug as FaqAudienceId} />
</BaseLayout>
