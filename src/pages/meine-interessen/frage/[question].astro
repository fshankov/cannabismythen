---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import {
  loadAllQuestions,
  getQuestionBySlug,
  getQuestionsForMyth,
  getAudience,
  loadMythPopupData,
  type FaqAudienceMeta,
  type FaqQuestion,
} from "@lib/faq";
import { buildGroupMetricsByMythId } from "@lib/dashboard/metrics";
import carmRawJson from "../../../../public/data/carm-data.json";
import FaqQuestionComponent from "@components/faq/FaqQuestion.astro";
import MythPopupHost from "@components/faq/MythPopupHost";
import "../../../styles/quiz.css";

export async function getStaticPaths() {
  const all = await loadAllQuestions();
  return all.map((q) => ({ params: { question: q.slug } }));
}

const { question: slug } = Astro.params;
const q = await getQuestionBySlug(slug!);
if (!q) return Astro.redirect("/meine-interessen/");

// Resolve current audience meta for the breadcrumb.
const currentAudience = await getAudience(q.audience);

// Find sibling questions in OTHER audiences that share the same primaryMyth —
// the new schema gives one file per audience-question, so audience-specific
// framing of the same myth lives in different files. Surface those as a rail.
type Sibling = { question: FaqQuestion; audience: FaqAudienceMeta };
const siblings: Sibling[] = [];
if (q.primaryMyth) {
  const related = await getQuestionsForMyth(q.primaryMyth);
  for (const other of related) {
    if (other.slug === q.slug) continue;
    if (other.audience === q.audience) continue;
    const aMeta = await getAudience(other.audience);
    if (aMeta) siblings.push({ question: other, audience: aMeta });
  }
}

// Popup data for inline myth links (same data the audience page uses).
// Loaded once and passed to FaqQuestionComponent via `popupData` prop so
// the nested FaqRelatedRail doesn't re-invoke the helper.
const popupData = await loadMythPopupData();
const { mythIndex, mythContentMap } = popupData;
const groupMetricsByMyth = buildGroupMetricsByMythId(carmRawJson.metrics);

const description =
  q.leadAnswer.slice(0, 160) || `Antwort zu: ${q.questionLong}`;
---

<BaseLayout title={q.questionLong} description={description} bgTexture>
  <article class="faq-single-question" data-reveal>
    <nav class="faq-audience-header__crumbs" aria-label="Brotkrumen">
      <a href="/meine-interessen/eltern/">Meine Interessen</a>
      {currentAudience && (
        <>
          <span aria-hidden="true">›</span>
          <a href={`/meine-interessen/${currentAudience.id}/`}>{currentAudience.cardLabel}</a>
        </>
      )}
      <span aria-hidden="true">›</span>
      <span aria-current="page">Einzelne Frage</span>
    </nav>

    <FaqQuestionComponent
      question={q}
      index={1}
      open={true}
      popupData={popupData}
    />

    {siblings.length > 0 && (
      <aside class="faq-also-see">
        <h2 class="faq-also-see__heading">
          Andere Zielgruppen zu diesem Thema:
        </h2>
        <ul class="faq-also-see__list">
          {siblings.map(({ question: sib, audience: a }) => (
            <li>
              <a
                href={`/meine-interessen/frage/${sib.slug}/`}
                style={`--audience-accent: ${a.accentColor}`}
              >
                <span aria-hidden="true">{a.emoji}</span>{" "}
                <span class="faq-also-see__audience">{a.cardLabel}:</span>{" "}
                <span class="faq-also-see__question">{sib.questionLong}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    <footer class="faq-audience-page__footer">
      <a href="/meine-interessen/eltern/">← Alle Zielgruppen</a>
    </footer>
  </article>

  <MythPopupHost
    client:load
    mythIndex={JSON.stringify(mythIndex)}
    mythContent={JSON.stringify(mythContentMap)}
    groupMetrics={JSON.stringify(groupMetricsByMyth)}
  />
</BaseLayout>
