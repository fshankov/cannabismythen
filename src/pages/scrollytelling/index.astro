---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPublishedEntries } from "@lib/content";

const entries = await getPublishedEntries("scrollytelling");

// Filter out chart-specifications (technical, not a narrative)
const narratives = entries.filter(([slug]) => slug !== "chart-specifications");
---

<BaseLayout title="Scrollytelling" description="Interaktive Erzählung zu Cannabis-Mythen">
  <h1>Scrollytelling: Cannabis-Mythen interaktiv</h1>
  <p>
    Entdecken Sie die überraschendsten Ergebnisse der CaRM-Forschung
    in einer interaktiven, datengetriebenen Erzählung.
  </p>

  <section class="scrollytelling-versions">
    {narratives.map(([slug, entry]) => {
      const e = entry as any;
      return (
        <a href={`/scrollytelling/${slug}/`} class="version-card">
          <h2>{e.title}</h2>
          {e.versionLabel && <span class="version-label">{e.versionLabel}</span>}
          {e.stepCount > 0 && <p>{e.stepCount} Schritte</p>}
          {e.summary && <p>{e.summary}</p>}
        </a>
      );
    })}
  </section>
</BaseLayout>
