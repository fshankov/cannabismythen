---
export const prerender = false;
// Auth is handled by /api/auth — this page only renders the login form.
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zugang — Cannabis: Mythen & Evidenz</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f4f4f0;
        font-family: system-ui, -apple-system, sans-serif;
        color: #1a1a1a;
      }

      .card {
        background: white;
        border-radius: 10px;
        padding: 2.5rem 3rem;
        width: 100%;
        max-width: 380px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.08);
        text-align: center;
      }

      h1 {
        font-size: 1.25rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
      }

      p.sub {
        font-size: 0.875rem;
        color: #666;
        margin-bottom: 1.75rem;
      }

      input[type="password"] {
        width: 100%;
        padding: 0.65rem 0.9rem;
        border: 1.5px solid #ddd;
        border-radius: 6px;
        font-size: 1rem;
        outline: none;
        transition: border-color 0.15s;
      }

      input[type="password"]:focus {
        border-color: #2d6a4f;
      }

      button {
        margin-top: 0.85rem;
        width: 100%;
        padding: 0.7rem;
        background: #2d6a4f;
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s;
      }

      button:hover { background: #1f4f3a; }

      .error {
        margin-top: 0.8rem;
        font-size: 0.85rem;
        color: #c0392b;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>Cannabis: Mythen &amp; Evidenz</h1>
      <p class="sub">Bitte geben Sie das Zugangspasswort ein.</p>
      <form id="loginForm">
        <input
          type="password"
          id="passwordInput"
          name="password"
          placeholder="Passwort"
          autocomplete="current-password"
          autofocus
          required
        />
        <button type="submit" id="submitBtn">Einloggen</button>
      </form>
      <p class="error" id="errorMsg" style="display:none">
        Falsches Passwort. Bitte versuchen Sie es erneut.
      </p>
    </div>

    <script>
      const form = document.getElementById('loginForm');
      const errorMsg = document.getElementById('errorMsg');
      const submitBtn = document.getElementById('submitBtn');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.style.display = 'none';
        submitBtn.disabled = true;
        submitBtn.textContent = '…';

        try {
          const body = new FormData(form);
          const res = await fetch('/api/auth', {
            method: 'POST',
            body,
            credentials: 'same-origin',
          });
          const json = await res.json();

          if (json.ok) {
            window.location.href = '/';
          } else {
            errorMsg.style.display = 'block';
            submitBtn.disabled = false;
            submitBtn.textContent = 'Einloggen';
          }
        } catch {
          errorMsg.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Einloggen';
        }
      });
    </script>
  </body>
</html>
