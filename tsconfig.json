{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@lib/*": ["src/lib/*"],
      "@content/*": ["src/content/*"],
      "@layouts/*": ["src/layouts/*"]
    }
  },
  "exclude": ["scripts", "_local", "dist", ".netlify"]
}
